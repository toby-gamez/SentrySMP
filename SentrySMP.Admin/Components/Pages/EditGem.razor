@using Microsoft.AspNetCore.Components.Forms
@page "/edit-gem/{id:int}"
@rendermode InteractiveServer
@using SentrySMP.Shared.DTOs
@inject ISentryApi Api
@inject ILogger<EditGem> Logger
@inject NavigationManager Navigation

<PageTitle>Edit Gem - SentrySMP Admin</PageTitle>


<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1>
                        <i class="bi bi-pencil-square me-2"></i>
                        Edit Gem
                    </h1>
                    <p class="text-muted">Update gems configuration</p>
                </div>
                <button class="btn btn-outline-secondary" @onclick="GoBack">
                    <i class="bi bi-arrow-left"></i> Back to Gems
                </button>
            </div>
        </div>
    </div>
    @if (loading)
    {
        <div class="d-flex justify-content-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (gemsNotFound)
    {
        <div class="alert alert-warning" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            Gem with ID @Id not found.
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-12">
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        @errorMessage
                    </div>
                }
                @if (!string.IsNullOrEmpty(successMessage))
                {
                    <div class="alert alert-success" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        @successMessage
                    </div>
                }
                <EditForm Model="gemsModel" OnValidSubmit="HandleValidSubmit">
                    <DataAnnotationsValidator />
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Name</label>
                                <InputText class="form-control" @bind-Value="gemsModel.Name" />
                                <ValidationMessage For="() => gemsModel.Name" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Description</label>
                                <InputTextArea class="form-control" @bind-Value="gemsModel.Description" />
                                <ValidationMessage For="() => gemsModel.Description" />
                            </div>
                            <ImageUploader Label="Gem Image" SubDirectory="gems"
                                           ImageUrl="@gemsModel.Image" ImageUrlChanged="@((string? url) => gemsModel.Image = url)" />

                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Price</label>
                                <InputNumber class="form-control" @bind-Value="gemsModel.Price" />
                                <ValidationMessage For="() => gemsModel.Price" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Sale (%)</label>
                                <InputNumber class="form-control" @bind-Value="gemsModel.Sale" />
                                <ValidationMessage For="() => gemsModel.Sale" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Global Max Order (Optional)</label>
                                <InputNumber class="form-control" @bind-Value="gemsModel.GlobalMaxOrder" placeholder="Leave empty for unlimited" />
                                <div class="form-text">Maximum total quantity per user across all orders (leave empty for unlimited)</div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Server</label>
                                <InputSelect class="form-select" @bind-Value="gemsModel.ServerId">
                                    <option value="">Select server</option>
                                    @foreach (var server in servers)
                                    {
                                        <option value="@server.Id">@server.Name</option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="() => gemsModel.ServerId" />
                            </div>
                        </div>
                    </div>
                    <div class="mb-3 mt-3">
                        <label class="form-label">Commands</label>
                        <div class="form-text text-muted mb-2">For replacing string with name use %player%.</div>
                        @if (gemsCommands == null || !gemsCommands.Any())
                        {
                            <div class="text-muted">No commands attached.</div>
                        }
                        @for (int i = 0; i < (gemsCommands?.Count ?? 0); i++)
                        {
                            var idx = i;
                            var cmd = gemsCommands![idx];
                            <div class="input-group mb-2">
                                <InputText @bind-Value="cmd.CommandText" class="form-control" />
                                <button type="button" class="btn btn-outline-danger" @onclick="() => RemoveGemCommand(idx)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        }
                        <button type="button" class="btn btn-sm btn-outline-primary" @onclick="AddGemCommand">
                            <i class="bi bi-plus"></i> Add Command
                        </button>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 mt-3">
                        <i class="bi bi-save"></i> Save Changes
                    </button>
                </EditForm>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }
    private UpdateGemDto gemsModel = new();
    private List<ServerResponse> servers = new();
    private string? errorMessage;
    private string? successMessage;
    private bool loading = true;
    private bool gemsNotFound = false;
    private List<CommandInputModel>? gemsCommands = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            loading = true;
            servers = (await Api.GetServersAsync()).ToList();
            var gems = await Api.GetGemAsync(Id);
            if (gems == null)
            {
                gemsNotFound = true;
                return;
            }
            gemsModel = new UpdateGemDto
            {
                Name = gems.Name,
                Description = gems.Description,
                Price = gems.Price,
                Sale = gems.Sale,
                Image = gems.Image,
                GlobalMaxOrder = gems.GlobalMaxOrder,
                ServerId = gems.Server?.Id ?? 0
            };
                if (gems.Commands != null && gems.Commands.Any())
                {
                    gemsCommands = gems.Commands.Select(c => new CommandInputModel { CommandText = c.CommandText }).ToList();
                }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading gems: {ex.Message}";
            Logger.LogError(ex, "Error loading gems");
        }
        finally
        {
            loading = false;
        }
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            errorMessage = null;
            successMessage = null;
            if (gemsCommands != null && gemsCommands.Any())
            {
                gemsModel.Commands = gemsCommands.Select(c => new CreateCommandDto { CommandText = c.CommandText }).ToList();
            }
            await Api.UpdateGemAsync(Id, gemsModel);
            successMessage = "Gem updated successfully! Redirecting...";
            StateHasChanged();
            await Task.Delay(1500);
            Navigation.NavigateTo("/gems");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error updating gems: {ex.Message}";
            Logger.LogError(ex, "Error updating gems");
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/gems");
    }

    private class CommandInputModel
    {
        public string CommandText { get; set; } = string.Empty;
    }

    private void AddGemCommand()
    {
        if (gemsCommands == null) gemsCommands = new List<CommandInputModel>();
        gemsCommands.Add(new CommandInputModel());
    }

    private void RemoveGemCommand(int index)
    {
        if (gemsCommands == null) return;
        if (index < 0 || index >= gemsCommands.Count) return;
        gemsCommands.RemoveAt(index);
    }
}
