@page "/vouchers"
@using SentrySMP.Shared.DTOs
@using SentrySMP.Shared.Interfaces
@inject ISentryApi Api
@inject ILogger<Vouchers> Logger
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>Vouchers - SentrySMP Admin</PageTitle>

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>
                    <i class="bi bi-tag-fill text-primary me-2"></i>
                    Voucher Management
                </h1>
                <a href="/add-voucher" class="btn btn-success">
                    <i class="bi bi-plus-circle-fill me-2"></i>
                    Create New Voucher
                </a>
            </div>

            @if (loading)
            {
                <div class="d-flex justify-content-center">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            }
            else if (errorMessage != null)
            {
                <div class="alert alert-danger" role="alert">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    @errorMessage
                </div>
            }
            else if (vouchers?.Any() == true)
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Code</th>
                                <th>Description</th>
                                <th>Discount</th>
                                <th>Scope</th>
                                <th>Valid From</th>
                                <th>Valid To</th>
                                <th>Uses</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var v in vouchers)
                            {
                                var now = DateTime.Now;
                                var isExpired = v.ExpirationDate < now;
                                var notStarted = v.StartDate > now;
                                <tr>
                                    <td>
                                        <code class="fw-bold">@v.Code</code>
                                    </td>
                                    <td>
                                        @{
                                            var desc = v.Description ?? "";
                                            <span>@(desc.Length > 60 ? desc.Substring(0, 60) + "..." : desc)</span>;
                                        }
                                    </td>
                                    <td>
                                        <span class="fw-bold">@($"{v.DiscountPercent.ToString("0.#")}%")</span>
                                    </td>
                                    <td>
                                        @if (v.Scope == "All")
                                        {
                                            <span class="badge bg-success">
                                                <i class="bi bi-ticket-perforated me-1"></i>
                                                All
                                            </span>
                                        }
                                        else if (v.Scope == "Category")
                                        {
                                            <span class="badge bg-primary">
                                                <i class="bi bi-grid-3x3-gap-fill me-1"></i>
                                                Category: @v.ScopeCategory
                                            </span>
                                        }
                                        else if (v.Scope == "Item")
                                        {
                                            <span class="badge text-white" style="background-color:#6f42c1;">
                                                <i class="bi bi-box-seam me-1"></i>
                                                Item: @v.ScopeCategory @if(v.ScopeItemId.HasValue){<text>#@v.ScopeItemId</text>}
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Unknown</span>
                                        }
                                    </td>
                                    <td>
                                        @v.StartDate.ToString("yyyy-MM-dd")
                                    </td>
                                    <td>
                                        @v.ExpirationDate.ToString("yyyy-MM-dd")
                                    </td>
                                    <td>
                                        @{
                                            var maxUsesText = v.MaxUses.HasValue ? v.MaxUses.Value.ToString() : "∞";
                                        }
                                        <span>@($"{v.CurrentUses} / {maxUsesText}")</span>
                                    </td>
                                    <td>
                                        <div class="d-flex flex-column">
                                            <div>
                                                @if (v.IsActive)
                                                {
                                                    <span class="badge bg-success me-1">Active</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger me-1">Inactive</span>
                                                }
                                            </div>
                                            <div class="mt-1">
                                                @if (isExpired)
                                                {
                                                    <span class="badge bg-warning text-dark">Expired</span>
                                                }
                                                else if (notStarted)
                                                {
                                                    <span class="badge text-white" style="background-color:#fd7e14;">Not started</span>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a href="/edit-voucher/@v.Id" class="btn btn-sm btn-outline-primary" title="Edit Voucher" data-bs-toggle="tooltip">
                                                <i class="bi bi-pencil-square me-1"></i>
                                                Edit
                                            </a>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteVoucher(v.Id, v.Code)" title="Delete Voucher" data-bs-toggle="tooltip">
                                                <i class="bi bi-trash3-fill me-1"></i>
                                                Delete
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info" role="alert">
                    <i class="bi bi-info-circle-fill"></i>
                    No vouchers found. Create your first voucher!
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<VoucherResponse>? vouchers;
    private bool loading = true;
    private string? errorMessage;
    private bool isInitialized = false;

    protected override async Task OnInitializedAsync()
    {
        if (!isInitialized)
        {
            isInitialized = true;
            await LoadVouchers();
        }
    }

    private async Task LoadVouchers()
    {
        try
        {
            loading = true;
            errorMessage = null;
            var list = await Api.GetVouchersAsync();
            vouchers = list?.OrderByDescending(v => v.StartDate).ToList();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading vouchers: {ex.Message}";
            Logger.LogError(ex, "Error loading vouchers");
        }
        finally
        {
            loading = false;
        }
    }

    private async Task DeleteVoucher(int id, string code)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete the voucher '{code}'?"))
        {
            try
            {
                await Api.DeleteVoucherAsync(id);
                await JSRuntime.InvokeVoidAsync("alert", "Voucher deleted successfully!");
                await LoadVouchers();
            }
            catch (Exception ex)
            {
                await JSRuntime.InvokeVoidAsync("alert", $"Error deleting voucher: {ex.Message}");
                Logger.LogError(ex, "Error deleting voucher {VoucherId}", id);
            }
        }
    }
}
