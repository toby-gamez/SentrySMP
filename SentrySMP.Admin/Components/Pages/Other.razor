@page "/other"
@using SentrySMP.Shared.DTOs
@using SentrySMP.Shared.Interfaces
@inject ISentryApi Api
@inject ILogger<Other> Logger
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>Other - SentrySMP Admin</PageTitle>

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>
                    <i class="bi bi-coin text-primary me-2"></i>
                    Other Management
                </h1>
                <a href="/add-other" class="btn btn-success">
                    <i class="bi bi-plus-circle-fill me-2"></i>
                    Create New Other
                </a>
            </div>
            @if (loading)
            {
                <div class="d-flex justify-content-center">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            }
            else if (errorMessage != null)
            {
                <div class="alert alert-danger" role="alert">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    @errorMessage
                </div>
            }
            else if (items?.Any() == true)
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th><i class="bi bi-image me-1"></i>Image</th>
                                <th><i class="bi bi-box me-1"></i>Name</th>
                                <th><i class="bi bi-file-text me-1"></i>Description</th>
                                <th><i class="bi bi-currency-euro me-1"></i>Price</th>
                                <th><i class="bi bi-server me-1"></i>Server</th>
                                <th><i class="bi bi-percent me-1"></i>Sale</th>
                                <th><i class="bi bi-terminal me-1"></i>Commands</th>
                                <th><i class="bi bi-gear me-1"></i>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in items)
                            {
                                <tr>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.Image))
                                        {
                                            <img src="@item.Image" alt="@item.Name" style="width: 50px; height: 50px; object-fit: cover;" class="rounded">
                                        }
                                        else
                                        {
                                            <div class="bg-secondary rounded d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                                <i class="bi bi-box-fill text-white"></i>
                                            </div>
                                        }
                                    </td>
                                    <td><strong>@item.Name</strong></td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.Description))
                                        {
                                            @(item.Description.Length > 50 ? item.Description.Substring(0, 50) + "..." : item.Description)
                                        }
                                    </td>
                                    <td>
                                        <strong class="text-success">
                                            <i class="bi bi-currency-euro me-1"></i>
                                            @item.Price.ToString("F2")
                                        </strong>
                                    </td>
                                    <td>
                                        @if (item.Server != null)
                                        {
                                            <span class="badge bg-info">
                                                <i class="bi bi-server me-1"></i>
                                                @item.Server.Name
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">
                                                <i class="bi bi-server me-1"></i>
                                                Unknown
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        @if (item.Sale > 0)
                                        {
                                            <span class="badge bg-danger">
                                                <i class="bi bi-percent me-1"></i>
                                                @item.Sale% OFF
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">
                                                <i class="bi bi-dash-circle me-1"></i>
                                                Regular
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        @if (item.Commands != null && item.Commands.Any())
                                        {
                                            var cmdText = string.Join(", ", item.Commands.Select(c => c.CommandText));
                                            <span class="badge bg-info" title="@cmdText">
                                                <i class="bi bi-terminal me-1"></i>
                                                @item.Commands.Count
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a href="/edit-other/@item.Id" class="btn btn-sm btn-outline-primary" title="Edit Item" data-bs-toggle="tooltip">
                                                <i class="bi bi-pencil-square me-1"></i>
                                                Edit
                                            </a>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteItem(item.Id)" title="Delete Item" data-bs-toggle="tooltip">
                                                <i class="bi bi-trash3-fill me-1"></i>
                                                Delete
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info" role="alert">
                    <i class="bi bi-info-circle-fill"></i>
                    No items found.
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<OtherResponse>? items;
    private bool loading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadItems();
    }

    private async Task LoadItems()
    {
        try
        {
            loading = true;
            errorMessage = null;
            items = (await Api.GetOthersAsync()).ToList();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading items: {ex.Message}";
            Logger.LogError(ex, "Error loading others");
        }
        finally
        {
            loading = false;
        }
    }

    private async Task DeleteItem(int id)
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete this item?"))
            return;
        try
        {
            await Api.DeleteOtherAsync(id);
            await LoadItems();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error deleting item: {ex.Message}";
            Logger.LogError(ex, "Error deleting other");
        }
    }
}
