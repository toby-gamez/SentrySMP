@using Microsoft.AspNetCore.Components.Forms
@page "/add-gems"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using SentrySMP.Shared.DTOs
@inject ISentryApi Api
@inject ILogger<AddGem> Logger
@inject NavigationManager Navigation

<PageTitle>Add Gem - SentrySMP Admin</PageTitle>

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1>
                        <i class="bi bi-plus-circle me-2"></i>
                        Add Gems
                    </h1>
                    <p class="text-muted">Create gems configuration</p>
                </div>
                <button class="btn btn-outline-secondary" @onclick="GoBack">
                    <i class="bi bi-arrow-left"></i> Back to Gems
                </button>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            @errorMessage
        </div>
    }
    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            @successMessage
        </div>
    }

    <EditForm Model="gemModel" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />
        <div class="row">
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <InputText class="form-control" @bind-Value="gemModel.Name" />
                    <ValidationMessage For="() => gemModel.Name" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <InputTextArea class="form-control" @bind-Value="gemModel.Description" />
                    <ValidationMessage For="() => gemModel.Description" />
                </div>
                <div class="mb-3">
                    <ImageUploader Label="Gem Image"
                                       SubDirectory="gems"
                                       ImageUrl="@gemModel.Image"
                                       ImageUrlChanged="@((string? url) => gemModel.Image = url)" />
                </div>
            </div>
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label">Price</label>
                    <InputNumber class="form-control" @bind-Value="gemModel.Price" />
                    <ValidationMessage For="() => gemModel.Price" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Sale (%)</label>
                    <InputNumber class="form-control" @bind-Value="gemModel.Sale" />
                    <ValidationMessage For="() => gemModel.Sale" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Global Max Order (Optional)</label>
                    <InputNumber class="form-control" @bind-Value="gemModel.GlobalMaxOrder" placeholder="Leave empty for unlimited" />
                    <div class="form-text">Maximum total quantity per user across all orders (leave empty for unlimited)</div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Server</label>
                    <InputSelect class="form-select" @bind-Value="gemModel.ServerId">
                        <option value="">Select server</option>
                        @foreach (var server in servers)
                        {
                            <option value="@server.Id">@server.Name</option>
                        }
                    </InputSelect>
                    <ValidationMessage For="() => gemModel.ServerId" />
                </div>
            </div>
        </div>
        <div class="mb-3 mt-3">
            <label class="form-label">Commands</label>
            <div class="form-text text-muted mb-2">For replacing string with name use %player%.</div>
            @if (gemCommands == null || !gemCommands.Any())
            {
                <div class="text-muted">No commands attached.</div>
            }
            @for (int i = 0; i < (gemCommands?.Count ?? 0); i++)
            {
                var idx = i;
                var cmd = gemCommands![idx];
                <div class="input-group mb-2">
                    <InputText @bind-Value="cmd.CommandText" class="form-control" />
                    <button type="button" class="btn btn-outline-danger" @onclick="() => RemoveGemCommand(idx)">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
            }
            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="AddGemCommand">
                <i class="bi bi-plus"></i> Add Command
            </button>
        </div>
        <div class="row">
            <div class="col-12">
                <div class="d-flex gap-2 justify-content-end">
                    <button type="button" class="btn btn-outline-secondary" @onclick="GoBack">
                        <i class="bi bi-x-circle me-1"></i> Cancel
                    </button>
                    <button type="submit" class="btn btn-primary btn-lg w-100 mt-3">
                        <i class="bi bi-plus-circle"></i> Create Gem
                    </button>
                </div>
            </div>
        </div>
    </EditForm>
</div>

@code {
    private CreateGemDto gemModel = new();
    private List<ServerResponse> servers = new();
    private string? errorMessage;
    private string? successMessage;
    private List<CommandInputModel>? gemCommands = new();
    private bool isSaving = false;

    protected override async Task OnInitializedAsync()
    {
        servers = (await Api.GetServersAsync()).ToList();
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            isSaving = true;
            errorMessage = null;
            successMessage = null;
            if (gemCommands != null && gemCommands.Any())
            {
                gemModel.Commands = gemCommands.Select(c => new CreateCommandDto { CommandText = c.CommandText }).ToList();
            }
            await Api.CreateGemAsync(gemModel);
            successMessage = "Gem created successfully!";
            Navigation.NavigateTo("/gems");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error creating gem: {ex.Message}";
            Logger.LogError(ex, "Error creating gem");
        }
        finally
        {
            isSaving = false;
        }
    }

    private class CommandInputModel
    {
        public string CommandText { get; set; } = string.Empty;
    }

    private void AddGemCommand()
    {
        if (gemCommands == null) gemCommands = new List<CommandInputModel>();
        gemCommands.Add(new CommandInputModel());
    }

    private void RemoveGemCommand(int index)
    {
        if (gemCommands == null) return;
        if (index < 0 || index >= gemCommands.Count) return;
        gemCommands.RemoveAt(index);
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/gems");
    }
}
