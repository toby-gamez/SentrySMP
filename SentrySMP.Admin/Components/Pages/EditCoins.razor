@using Microsoft.AspNetCore.Components.Forms
@page "/edit-coin/{id:int}"
@rendermode InteractiveServer
@using SentrySMP.Shared.DTOs
@inject ISentryApi Api
@inject ILogger<EditCoins> Logger
@inject NavigationManager Navigation

<PageTitle>Edit Coin - SentrySMP Admin</PageTitle>


<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1>
                        <i class="bi bi-pencil-square me-2"></i>
                        Edit Coin
                    </h1>
                    <p class="text-muted">Update coins configuration</p>
                </div>
                <button class="btn btn-outline-secondary" @onclick="GoBack">
                    <i class="bi bi-arrow-left"></i> Back to Coins
                </button>
            </div>
        </div>
    </div>
    @if (loading)
    {
        <div class="d-flex justify-content-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (coinsNotFound)
    {
        <div class="alert alert-warning" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            Coin with ID @Id not found.
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-12">
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        @errorMessage
                    </div>
                }
                @if (!string.IsNullOrEmpty(successMessage))
                {
                    <div class="alert alert-success" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        @successMessage
                    </div>
                }
                <EditForm Model="coinsModel" OnValidSubmit="HandleValidSubmit">
                    <DataAnnotationsValidator />
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Name</label>
                                <InputText class="form-control" @bind-Value="coinsModel.Name" />
                                <ValidationMessage For="() => coinsModel.Name" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Description</label>
                                <InputTextArea class="form-control" @bind-Value="coinsModel.Description" />
                                <ValidationMessage For="() => coinsModel.Description" />
                            </div>
                            <ImageUploader Label="Coin Image" SubDirectory="coins"
                                           ImageUrl="@coinsModel.Image" ImageUrlChanged="@((string? url) => coinsModel.Image = url)" />

                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label">Price</label>
                                <InputNumber class="form-control" @bind-Value="coinsModel.Price" />
                                <ValidationMessage For="() => coinsModel.Price" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Sale (%)</label>
                                <InputNumber class="form-control" @bind-Value="coinsModel.Sale" />
                                <ValidationMessage For="() => coinsModel.Sale" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Global Max Order (Optional)</label>
                                <InputNumber class="form-control" @bind-Value="coinsModel.GlobalMaxOrder" placeholder="Leave empty for unlimited" />
                                <div class="form-text">Maximum total quantity per user across all orders (leave empty for unlimited)</div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Server</label>
                                <InputSelect class="form-select" @bind-Value="coinsModel.ServerId">
                                    <option value="">Select server</option>
                                    @foreach (var server in servers)
                                    {
                                        <option value="@server.Id">@server.Name</option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="() => coinsModel.ServerId" />
                            </div>
                        </div>
                    </div>
                    <div class="mb-3 mt-3">
                        <label class="form-label">Commands</label>
                        <div class="form-text text-muted mb-2">For replacing string with name use %player%.</div>
                        @if (coinsCommands == null || !coinsCommands.Any())
                        {
                            <div class="text-muted">No commands attached.</div>
                        }
                        @for (int i = 0; i < (coinsCommands?.Count ?? 0); i++)
                        {
                            var idx = i;
                            var cmd = coinsCommands![idx];
                            <div class="input-group mb-2">
                                <InputText @bind-Value="cmd.CommandText" class="form-control" />
                                <button type="button" class="btn btn-outline-danger" @onclick="() => RemoveCoinCommand(idx)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        }
                        <button type="button" class="btn btn-sm btn-outline-primary" @onclick="AddCoinCommand">
                            <i class="bi bi-plus"></i> Add Command
                        </button>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 mt-3">
                        <i class="bi bi-save"></i> Save Changes
                    </button>
                </EditForm>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }
    private UpdateCoinDto coinsModel = new();
    private List<ServerResponse> servers = new();
    private string? errorMessage;
    private string? successMessage;
    private bool loading = true;
    private bool coinsNotFound = false;
    private List<CommandInputModel>? coinsCommands = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            loading = true;
            servers = (await Api.GetServersAsync()).ToList();
            var coins = await Api.GetCoinAsync(Id);
            if (coins == null)
            {
                coinsNotFound = true;
                return;
            }
            coinsModel = new UpdateCoinDto
            {
                Name = coins.Name,
                Description = coins.Description,
                Price = coins.Price,
                Sale = coins.Sale,
                Image = coins.Image,
                GlobalMaxOrder = coins.GlobalMaxOrder,
                ServerId = coins.Server?.Id ?? 0
            };
                if (coins.Commands != null && coins.Commands.Any())
                {
                    coinsCommands = coins.Commands.Select(c => new CommandInputModel { CommandText = c.CommandText }).ToList();
                }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading coins: {ex.Message}";
            Logger.LogError(ex, "Error loading coins");
        }
        finally
        {
            loading = false;
        }
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            errorMessage = null;
            successMessage = null;
            if (coinsCommands != null && coinsCommands.Any())
            {
                coinsModel.Commands = coinsCommands.Select(c => new CreateCommandDto { CommandText = c.CommandText }).ToList();
            }
            await Api.UpdateCoinAsync(Id, coinsModel);
            successMessage = "Coin updated successfully! Redirecting...";
            StateHasChanged();
            await Task.Delay(1500);
            Navigation.NavigateTo("/coins");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error updating coins: {ex.Message}";
            Logger.LogError(ex, "Error updating coins");
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/coins");
    }

    private class CommandInputModel
    {
        public string CommandText { get; set; } = string.Empty;
    }

    private void AddCoinCommand()
    {
        if (coinsCommands == null) coinsCommands = new List<CommandInputModel>();
        coinsCommands.Add(new CommandInputModel());
    }

    private void RemoveCoinCommand(int index)
    {
        if (coinsCommands == null) return;
        if (index < 0 || index >= coinsCommands.Count) return;
        coinsCommands.RemoveAt(index);
    }
}
