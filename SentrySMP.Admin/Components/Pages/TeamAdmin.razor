@page "/team-admin"
@using SentrySMP.Shared.DTOs
@using SentrySMP.Shared.Interfaces
@inject SentrySMP.Shared.Interfaces.ISentryApi Api
@rendermode InteractiveServer
@attribute [StreamRendering]

<h1>Team Admin</h1>

<div class="mb-3">
    <h3>Manage Team Ranks</h3>
    <div class="d-flex gap-2 align-items-center mb-2">
        <input class="form-control" style="max-width:220px" placeholder="Rank name" @bind="newRankName" />
        <input class="form-control form-control-color" style="max-width:64px; padding:0;" type="color" @bind="newRankColor" />
        <button class="btn btn-primary" @onclick="CreateRank">Add Rank</button>
    </div>
    <div>
        @if (ranks?.Any() == true)
        {
            <div class="list-group">
                @foreach (var rr in ranks)
                {
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <div class="d-flex gap-2 align-items-center">
                            <input class="form-control" style="max-width:200px" @bind="rr.Name" />
                            <input class="form-control form-control-color" style="max-width:64px; padding:0;" type="color" @bind="rr.HexColor" />
                        </div>
                        <div>
                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="async () => await UpdateRank(rr)">Save</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="async () => await DeleteRank(rr.Id)">Delete</button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
@if (team == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="mb-3">
        <button class="btn btn-primary" @onclick="AddCategory">Add Category</button>
        <button class="btn btn-success ms-2" @onclick="Save">Save Changes</button>
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="@statusClass mt-2" role="alert">@statusMessage</div>
    }
    @for (int i = 0; i < team.Categories.Count; i++)
    {
        var cat = team.Categories[i];
        var index = i;
        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div class="d-flex align-items-center flex-grow-1">
                        <div class="btn-group me-2">
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => MoveCategoryUp(index)" disabled="@(index == 0)">▲</button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => MoveCategoryDown(index)" disabled="@(index == team.Categories.Count - 1)">▼</button>
                        </div>
                        <input class="form-control me-2" style="max-width:400px" @bind="cat.Name" />
                    </div>
                    <div>
                        <button class="btn btn-danger ms-2" @onclick="() => RemoveCategory(cat.Id)">Delete Category</button>
                    </div>
                </div>

                <div class="row mt-3">
                    @for (int j = 0; j < cat.Members.Count; j++)
                    {
                        var m = cat.Members[j];
                        var memberIndex = j;
                        var categoryId = cat.Id;
                        <div class="col-md-4 mb-2">
                            <div class="input-group">
                                <div class="btn-group-vertical me-1">
                                    <button class="btn btn-sm btn-outline-secondary" style="padding:0 4px;font-size:0.7rem;line-height:1;" @onclick="() => MoveMemberUp(categoryId, memberIndex)" disabled="@(memberIndex == 0)">▲</button>
                                    <button class="btn btn-sm btn-outline-secondary" style="padding:0 4px;font-size:0.7rem;line-height:1;" @onclick="() => MoveMemberDown(categoryId, memberIndex)" disabled="@(memberIndex == cat.Members.Count - 1)">▼</button>
                                </div>
                                <img src="@GetSkinUrl(m)" style="width:48px;height:48px;object-fit:cover;" />
                                <input class="form-control ms-2" placeholder="Minecraft name" @bind="m.MinecraftName" @bind:event="oninput" />
                                <select class="form-select ms-2" style="max-width:160px" @bind="m.TeamRankId">
                                    <option value="">—</option>
                                    @foreach (var rr in ranks)
                                    {
                                        <option value="@rr.Id">@rr.Name</option>
                                    }
                                </select>
                                <span class="ms-2 align-self-center">
                                    @if (m.Rank != null)
                                    {
                                        <span class="role-badge" style="background-color:@(string.IsNullOrWhiteSpace(m.Rank.HexColor) ? "#666" : m.Rank.HexColor)">@m.Rank.Name</span>
                                    }
                                </span>
                                <button class="btn btn-outline-danger" @onclick="() => RemoveMember(cat.Id, m.Id)">X</button>
                            </div>
                        </div>
                    }
                </div>

                <div class="mt-2">
                    <button class="btn btn-secondary" @onclick="() => AddMember(cat.Id)">Add Member</button>
                </div>
            </div>
        </div>
    }
}

@code {
    private TeamResponseDto? team;
    private List<TeamRankDto> ranks = new();
    private string? statusMessage;
    private string statusClass = "";
    private string newRankName = string.Empty;
    private string newRankColor = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        try
        {
            team = await Api.GetTeamAsync();
            team ??= new TeamResponseDto();
            var r = await Api.GetTeamRanksAsync();
            ranks = r.ToList();
        }
        catch
        {
            team = new TeamResponseDto();
            ranks = new List<TeamRankDto>();
        }
    }

    private void AddCategory()
    {
        team!.Categories.Add(new TeamCategoryDto { Name = "New Category" });
    }

    private void RemoveCategory(string id)
    {
        var cat = team!.Categories.FirstOrDefault(c => c.Id == id);
        if (cat != null) team.Categories.Remove(cat);
    }

    private void AddMember(string categoryId)
    {
        var cat = team!.Categories.FirstOrDefault(c => c.Id == categoryId);
        if (cat == null) return;
        cat.Members.Add(new TeamMemberDto { MinecraftName = "", TeamRankId = null });
    }

    private async Task CreateRank()
    {
        try
        {
            var dto = new TeamRankDto { Name = newRankName?.Trim() ?? string.Empty, HexColor = newRankColor?.Trim() ?? string.Empty };
            var created = await Api.CreateTeamRankAsync(dto);
            ranks.Add(created);
            newRankName = string.Empty;
            newRankColor = string.Empty;
        }
        catch (Exception ex)
        {
            statusMessage = "Failed to create rank: " + ex.Message;
            statusClass = "alert alert-danger";
        }
    }

    private async Task DeleteRank(int id)
    {
        try
        {
            await Api.DeleteTeamRankAsync(id);
            var e = ranks.FirstOrDefault(r => r.Id == id);
            if (e != null) ranks.Remove(e);
        }
        catch (Exception ex)
        {
            statusMessage = "Failed to delete rank: " + ex.Message;
            statusClass = "alert alert-danger";
        }
    }

    private async Task UpdateRank(TeamRankDto rr)
    {
        try
        {
            var dto = new TeamRankDto { Id = rr.Id, Name = rr.Name, HexColor = rr.HexColor };
            await Api.UpdateTeamRankAsync(rr.Id, dto);
            statusMessage = "Rank updated.";
            statusClass = "alert alert-success";
        }
        catch (Exception ex)
        {
            statusMessage = "Failed to update rank: " + ex.Message;
            statusClass = "alert alert-danger";
        }
    }

    private void RemoveMember(string categoryId, string memberId)
    {
        var cat = team!.Categories.FirstOrDefault(c => c.Id == categoryId);
        if (cat == null) return;
        var m = cat.Members.FirstOrDefault(x => x.Id == memberId);
        if (m != null) cat.Members.Remove(m);
    }

    private string GetSkinUrl(TeamMemberDto m)
    {
        if (!string.IsNullOrEmpty(m.SkinUrl)) return m.SkinUrl!;
        var name = string.IsNullOrWhiteSpace(m.MinecraftName) ? "steve" : m.MinecraftName;
        return $"https://minotar.net/helm/{Uri.EscapeDataString(name)}/48";
    }

    private string GetRoleClass(string? role)
    {
        if (string.IsNullOrWhiteSpace(role)) return "role-DEFAULT";
        var cleaned = new string(role.ToUpperInvariant().Where(c => char.IsLetterOrDigit(c)).ToArray());
        if (string.IsNullOrEmpty(cleaned)) return "role-DEFAULT";
        return $"role-{cleaned}";
    }

    private void MoveCategoryUp(int index)
    {
        if (index <= 0 || team == null) return;
        var temp = team.Categories[index];
        team.Categories[index] = team.Categories[index - 1];
        team.Categories[index - 1] = temp;
    }

    private void MoveCategoryDown(int index)
    {
        if (team == null || index >= team.Categories.Count - 1) return;
        var temp = team.Categories[index];
        team.Categories[index] = team.Categories[index + 1];
        team.Categories[index + 1] = temp;
    }

    private void MoveMemberUp(string categoryId, int memberIndex)
    {
        var cat = team!.Categories.FirstOrDefault(c => c.Id == categoryId);
        if (cat == null || memberIndex <= 0) return;
        var temp = cat.Members[memberIndex];
        cat.Members[memberIndex] = cat.Members[memberIndex - 1];
        cat.Members[memberIndex - 1] = temp;
    }

    private void MoveMemberDown(string categoryId, int memberIndex)
    {
        var cat = team!.Categories.FirstOrDefault(c => c.Id == categoryId);
        if (cat == null || memberIndex >= cat.Members.Count - 1) return;
        var temp = cat.Members[memberIndex];
        cat.Members[memberIndex] = cat.Members[memberIndex + 1];
        cat.Members[memberIndex + 1] = temp;
    }

    private async Task Save()
    {
        if (team == null) return;
        statusMessage = null;
        try
        {
            await Api.SaveTeamAsync(team);
            await Load();
            statusMessage = "Saved successfully.";
            statusClass = "alert alert-success";
        }
        catch (Exception ex)
        {
            statusMessage = $"Error saving: {ex.Message}";
            statusClass = "alert alert-danger";
            Console.WriteLine($"Failed to save team: {ex.Message}");
        }
    }
}
