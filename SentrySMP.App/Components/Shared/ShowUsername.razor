@inject SentrySMP.App.Authentication.UserService UserService

@inject NavigationManager Navigation
@inject SentrySMP.Shared.Interfaces.IStatusService StatusService
@inject SentrySMP.App.Components.State.CartSidebarState CartSidebarState
@inject SentrySMP.Shared.Interfaces.IGameServerService GameServerService
@inject SentrySMP.Shared.Interfaces.ITeamRankService TeamRankService
@inject Microsoft.Extensions.Logging.ILogger<ShowUsername> Logger
@using SentrySMP.App.Components.Pages
@implements IDisposable
@rendermode InteractiveServer

@if (!string.IsNullOrEmpty(CurrentDisplay))
{
    <div class="login-info">
        <img src="@((!string.IsNullOrEmpty(CurrentDisplay) && CurrentDisplay.StartsWith(".")) ? "https://minotar.net/helm/MHF_Steve/100" : ((!string.IsNullOrEmpty(SkinUrl) && string.Equals(Edition, "java", StringComparison.OrdinalIgnoreCase)) ? SkinUrl : "https://minotar.net/helm/MHF_Steve/100"))" class="skin-img" alt="skin" />
        <div>
            <div>
                @if (!string.IsNullOrWhiteSpace(_playerRankName))
                {
                    <span class="rank-badge" style="background:@(_playerRankHex ?? "#444"); color:#fff; padding:2px 8px; border-radius:4px; margin-right:6px; font-size:0.75em;"><strong>@_playerRankName</strong></span>
                }
                <strong>@CurrentDisplay</strong>
            </div>
        </div>
    </div>
    <div>
        <button class="secondary" @onclick="Logout">Log out</button>
        <button class="secondary" @onclick="OpenProfile">Profile</button>
        <button class="great-button" @onclick="OpenCart"><i class="bi bi-cart-fill"></i> Cart</button>
    </div>
}
else
{
    <div class="login-info">
            <img src="https://minotar.net/helm/MHF_Steve/100" class="skin-img" alt="skin" />
        <div>
            <div><strong>Guest</strong></div>
        </div>
    </div>
    <div>
        <button class="great-button" onclick="LogIn()">Log in</button>
    </div>
    <script>
        function LogIn() {
            window.location.href = "/login";
        }
    </script>
}

@code {
    private string? CurrentDisplay;
    private string? SkinUrl;
    private string? Edition;
    private string? _playerRankName;
    private string? _playerRankHex;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var info = await UserService.GetUserInfoAsync();
            Logger?.LogInformation("ShowUsername: UserService returned LoggedIn={LoggedIn} Username={Username}", info.LoggedIn, info.Username);
            System.Console.WriteLine($"ShowUsername: UserService returned LoggedIn={info.LoggedIn} Username={info.Username}");
            if (info.LoggedIn)
            {
                CurrentDisplay = info.Username;
                Edition = info.Edition;
                SkinUrl = info.Skin;
                // Try to fetch rank and color from game server and team ranks
                try
                {
                    if (!string.IsNullOrWhiteSpace(CurrentDisplay))
                    {
                        Logger?.LogInformation("ShowUsername: fetching player info for {Username}", CurrentDisplay);
                        System.Console.WriteLine($"ShowUsername: fetching player info for {CurrentDisplay}");
                        var p = await GameServerService.GetPlayerInfoAsync(CurrentDisplay);
                        if (p == null)
                        {
                            Logger?.LogWarning("ShowUsername: GameServerService returned null for {Username}", CurrentDisplay);
                            System.Console.WriteLine($"ShowUsername: GameServerService returned null for {CurrentDisplay}");
                        }
                        else
                        {
                            Logger?.LogInformation("ShowUsername: GameServerService response for {Username}: Rank={Rank} Coins={Coins} Money={Money} Error={Error}", CurrentDisplay, p.Rank, p.Coins, p.Money, p.Error);
                            System.Console.WriteLine($"ShowUsername: GameServerService response for {CurrentDisplay}: Rank={p.Rank} Coins={(p.Coins?.ToString() ?? "null")} Money={(p.Money?.ToString() ?? "null")} Error={p.Error}");
                            if (!string.IsNullOrWhiteSpace(p.Rank))
                            {
                                _playerRankName = p.Rank;
                                var tr = await TeamRankService.GetByNameAsync(_playerRankName);
                                if (tr == null)
                                {
                                    Logger?.LogWarning("ShowUsername: TeamRankService returned null for rank {Rank}", _playerRankName);
                                    System.Console.WriteLine($"ShowUsername: TeamRankService returned null for rank {_playerRankName}");
                                }
                                else
                                {
                                    _playerRankHex = tr.HexColor;
                                    Logger?.LogInformation("ShowUsername: Resolved rank {Rank} to color {Color}", _playerRankName, _playerRankHex);
                                    System.Console.WriteLine($"ShowUsername: Resolved rank {_playerRankName} to color {_playerRankHex}");
                                }
                            }
                        }
                    }
                }
                catch (Exception ex)
                {
                    Logger?.LogError(ex, "ShowUsername: Exception while fetching player/rank for {Username}", CurrentDisplay);
                    System.Console.WriteLine($"ShowUsername: Exception while fetching player/rank for {CurrentDisplay}: {ex.Message}");
                }
                StateHasChanged();
            }
            UserService.OnChange += OnUserChanged;
        }
    }

    private async void OnUserChanged()
    {
        var info = await UserService.GetUserInfoAsync();
        Logger?.LogInformation("ShowUsername.OnUserChanged: LoggedIn={LoggedIn} Username={Username}", info.LoggedIn, info.Username);
        System.Console.WriteLine($"ShowUsername.OnUserChanged: LoggedIn={info.LoggedIn} Username={info.Username}");
        if (!info.LoggedIn)
        {
            CurrentDisplay = null;
            SkinUrl = null;
            Edition = null;
            _playerRankName = null;
            _playerRankHex = null;
        }
        else
        {
            CurrentDisplay = info.Username;
            Edition = info.Edition;
            SkinUrl = info.Skin;
            try
            {
                if (!string.IsNullOrWhiteSpace(CurrentDisplay))
                {
                    Logger?.LogInformation("ShowUsername: OnUserChanged fetching player info for {Username}", CurrentDisplay);
                    System.Console.WriteLine($"ShowUsername: OnUserChanged fetching player info for {CurrentDisplay}");
                    var p = await GameServerService.GetPlayerInfoAsync(CurrentDisplay);
                    if (p == null)
                    {
                        Logger?.LogWarning("ShowUsername: OnUserChanged GameServerService returned null for {Username}", CurrentDisplay);
                        System.Console.WriteLine($"ShowUsername: OnUserChanged GameServerService returned null for {CurrentDisplay}");
                    }
                    else
                    {
                        Logger?.LogInformation("ShowUsername: OnUserChanged GameServerService response for {Username}: Rank={Rank} Error={Error}", CurrentDisplay, p.Rank, p.Error);
                        System.Console.WriteLine($"ShowUsername: OnUserChanged GameServerService response for {CurrentDisplay}: Rank={p.Rank} Coins={(p.Coins?.ToString() ?? "null")} Money={(p.Money?.ToString() ?? "null")} Error={p.Error}");
                        if (!string.IsNullOrWhiteSpace(p.Rank))
                        {
                            _playerRankName = p.Rank;
                            var tr = await TeamRankService.GetByNameAsync(_playerRankName);
                            if (tr != null) _playerRankHex = tr.HexColor;
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                Logger?.LogError(ex, "ShowUsername: OnUserChanged exception fetching player/rank for {Username}", CurrentDisplay);
                System.Console.WriteLine($"ShowUsername: OnUserChanged exception fetching player/rank for {CurrentDisplay}: {ex.Message}");
            }
        }
        StateHasChanged();
    }

    private async Task Logout()
    {
        await UserService.SetUsernameAsync(null);
        await UserService.SetEditionAsync(null);
    }

    private void OpenCart() => CartSidebarState.Open();

    private void OpenProfile() => Navigation.NavigateTo("/profile");

    public void Dispose()
    {
        UserService.OnChange -= OnUserChanged;
    }
}
