@page "/active-players"
@using SentrySMP.Shared.DTOs
@using SentrySMP.Shared.Interfaces
@inject IGameServerService GameServerService
@inject ITeamRankService TeamRankService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Active Players - SentrySMP</PageTitle>

@if (_loading)
{
    <p><em>Loading...</em></p>
}
else if (_error != null)
{
    <div class="alert alert-danger">@_error</div>
}
else if (_players.Count == 0)
{
    <div class="alert alert-info">No players are currently online.</div>
}
else
{
    <ul class="ban-list">
        @foreach (var player in _players)
        {
            <li class="ban-item">
                <div class="ban-item-header">
                    <img src="https://minotar.net/helm/@(Uri.EscapeDataString(player.Name ?? "MHF_Steve"))/32"
                         alt="@player.Name"
                         class="ban-avatar skin-img" />
                    <div>
                        @{ var rankName = ParseRankName(player.Rank); }
                        @if (!string.IsNullOrWhiteSpace(rankName) && _rankColors.TryGetValue(rankName, out var hex))
                        {
                            <span class="rank-badge" style="background:@(hex ?? "#444"); color:#fff; padding:2px 8px; border-radius:4px; margin-right:6px; font-size:0.75em;"><strong>@rankName</strong></span>
                        }
                        else if (!string.IsNullOrWhiteSpace(rankName))
                        {
                            <span class="rank-badge" style="background:#444; color:#fff; padding:2px 8px; border-radius:4px; margin-right:6px; font-size:0.75em;"><strong>@rankName</strong></span>
                        }
                        <span class="ban-name">@(player.Name ?? "Unknown")</span>
                    </div>
                </div>
                <button class="secondary login-bar-icon" title="Profile" @onclick="() => OpenProfile(player.Name)"><i class="bi bi-person-fill"></i></button>
            </li>
        }
    </ul>
    <p class="text-muted mb-3">@_players.Count player@(_players.Count == 1 ? "" : "s") online</p>
}


@code {
    private List<OnlinePlayerEntry> _players = new();
    private bool _loading = true;
    private string? _error;
    private Dictionary<string, string?> _rankColors = new(StringComparer.OrdinalIgnoreCase);

    private static string? ParseRankName(string? rank)
    {
        if (string.IsNullOrWhiteSpace(rank)) return null;
        if (rank.StartsWith("%img_") && rank.EndsWith("%"))
            return rank[5..^1];
        return rank;
    }

    private void OpenProfile(string? playerName)
    {
        if (!string.IsNullOrWhiteSpace(playerName))
        {
            NavigationManager.NavigateTo($"/profile/{Uri.EscapeDataString(playerName)}");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await GameServerService.GetOnlinePlayersAsync();
            if (result == null)
            {
                _error = "GameServer is not configured.";
            }
            else if (result.Error != null)
            {
                _error = result.Error;
            }
            else
            {
                _players = result.Players;

                var allRanks = await TeamRankService.GetAllAsync();
                _rankColors = new Dictionary<string, string?>(StringComparer.OrdinalIgnoreCase);
                foreach (var r in allRanks.Where(r => !string.IsNullOrWhiteSpace(r.Name)))
                    _rankColors[r.Name!] = r.HexColor;
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
