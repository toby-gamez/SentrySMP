@page "/checkout"
@using SentrySMP.Shared.DTOs
@using Microsoft.AspNetCore.WebUtilities
@using SentrySMP.App.Components.State
@using System.Text.Json
@using System.Net.Http.Json
@inject SentrySMP.App.Components.State.CartState CartState
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@inject NavigationManager NavigationManager
@inject Microsoft.JSInterop.IJSRuntime JS
@inject SentrySMP.Shared.Interfaces.ICheckoutApi CheckoutApi
@inject System.Net.Http.HttpClient Http
@inject SentrySMP.Shared.Interfaces.ITransactionsService TransactionsService
@inject SentrySMP.App.Authentication.UserService UserService
@inject SentrySMP.Shared.Interfaces.IRconService RconService
@inject SentrySMP.Shared.Interfaces.IStatusService StatusService
@inject Microsoft.Extensions.Logging.ILoggerFactory LoggerFactory
@inject SentrySMP.App.Services.IBackgroundTaskQueue BackgroundQueue
@inject SentrySMP.Shared.Interfaces.ISentryApi SentryApi
@inject SentrySMP.Shared.Interfaces.IPurchaseTrackingService PurchaseTrackingService
@inject SentrySMP.App.Components.State.VoucherState VoucherState
@rendermode InteractiveServer
<PageTitle>Checkout - SentrySMP</PageTitle>

<div class="main-wrapper">
    <h1 class="main">Checkout</h1>
</div>
    @if (_paymentSucceeded)
    {
        <div style="font-size: 5rem; text-align:center; color:#44ae44;">
            <i class="bi bi-check-circle"></i>
        </div>
        <div class="alert alert-success mt-4">

            <div class="info">
                @(_successMessage ?? "Payment successful.")
            </div>
            @if (_wasRedirectStatusSuccess && string.IsNullOrWhiteSpace(_deliveryStatusMessage) && string.IsNullOrWhiteSpace(_failureMessage))
            {
                <p><em>If the webpage keeps reloading, <u>it wants to send you your purchased items</u>.</em>If the problem persists, please contact us.</p>
            }
            <button @onclick="ContinueShopping">Continue shopping</button>
        </div>

        @if (_deliveryResult != null)
        {
                <h2>Status</h2>
                <div class="table-wrapper">
                    <table>
                        <thead>
                            <tr>
                                <th>Command for</th>
                                <th class="text-center">Status</th>
                                <th>Details</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cr in _deliveryResult.CommandResults)
                            {
                                <tr class="@(cr.Succeeded ? "table-success" : "table-danger")">
                                    <td style="min-width:160px;">@(cr.ProductName ?? cr.CommandText)</td>
                                    <td class="text-center" style="color: @(cr.Succeeded ? "#44ae44" : "#dc3545")">@(cr.Succeeded ? "OK" : "FAILED")</td>
                                    <td>
                                        @{
                                            var detail = !string.IsNullOrEmpty(cr.Response) ? cr.Response : cr.ErrorMessage;
                                        }
                                        @if (!string.IsNullOrEmpty(detail))
                                        {
                                            <span title="@detail" style="display:inline-block; max-width:420px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">@TruncateCompact(detail, 100)</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
        }

        <!-- Purchase confirmation for cases where delivery failed -->
        @if (_paymentSucceeded && ((_deliveryResult != null && !_deliveryResult.AllSucceeded) || (!string.IsNullOrWhiteSpace(_deliveryStatusMessage) && _deliveryStatusMessage.IndexOf("failed", StringComparison.OrdinalIgnoreCase) >= 0)))  
        {
            <div style="background:#ffffff; color:#000; border:1px solid #ddd; border-radius:10px; padding:16px; margin-top:1rem; box-shadow: 0 1px 2px rgba(0,0,0,0.04); position:relative;">
                <h2 style="color:#000;">Purchase confirmation</h2>
                <div style="position:absolute; right:16px; top:12px; font-size:2.4rem; line-height:1;">
                    <i class="bi @( (_deliveryResult != null && _deliveryResult.AllSucceeded) ? "bi-check-circle" : "bi-x-circle")" style="color:@( (_deliveryResult != null && _deliveryResult.AllSucceeded) ? "#44ae44" : "#dc3545")"></i>
                </div>
                <div class="mb-2">Transaction ID: <strong>@(_lastTransactionId?.ToString() ?? "N/A")</strong>
                    <button class="btn btn-sm btn-outline-secondary ms-2" @onclick="CopyTransactionId">Copy ID</button>
                    <button class="btn btn-sm btn-outline-secondary ms-2" @onclick="CopyIssue">Copy full issue</button>
                    @if (!string.IsNullOrWhiteSpace(_copyFeedback))
                    {
                        <span class="ms-2 small text-muted">@_copyFeedback</span>
                    }
                </div>

                <div class="alert alert-warning">
                    <strong>Delivery issue:</strong>
                    <div class="mt-1 small text-muted">Some items could not be delivered to the server automatically. Keep your transaction ID and contact support if the items do not arrive.</div>
                    @if (!string.IsNullOrWhiteSpace(_deliveryStatusMessage))
                    {
                        <div class="mt-2">Status: @_deliveryStatusMessage</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(_failureMessage))
                    {
                        <div class="mt-2">Details: @_failureMessage</div>
                    }
                    @if (_deliveryResult?.CommandResults != null)
                    {
                        var failedResults = _deliveryResult.CommandResults
                            .Where(cr => !cr.Succeeded)
                            .Select(cr => new { cr.ProductName, cr.CommandText, Detail = !string.IsNullOrEmpty(cr.ErrorMessage) ? cr.ErrorMessage : cr.Response })
                            .Where(x => !string.IsNullOrEmpty(x.Detail))
                            .ToList();
                        @foreach (var fr in failedResults)
                        {
                            <div class="mt-1 small">
                                <strong>@(fr.ProductName ?? fr.CommandText):</strong> @fr.Detail
                            </div>
                        }
                    }
                    @if (_canRetryDelivery && !_retryDeliveryInProgress)
                    {
                        <div class="mt-3 d-flex align-items-center gap-3">
                            <div>
                                <i class="bi bi-info-circle me-1"></i>
                                <strong>Player not connected.</strong> Connect to the server and click Try Again to deliver your items.
                            </div>
                            <button class="great-button" @onclick="TryDeliveryAgainAsync">Try Again</button>
                        </div>
                    }
                    @if (_retryDeliveryInProgress)
                    {
                        <div class="mt-3">
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            Retrying delivery...
                        </div>
                    }
                </div>

                <!-- order details moved below the confirmation box -->
            </div>
        }
        @if (_lastOrderItems != null && _lastOrderItems.Count > 0)
        {
            <div class="mt-2">
                <h2>Order details</h2>
                <div class="table-wrapper">
                    <table class="table table-sm mt-2">
                        <thead>
                            <tr>
                                <th>Item</th>
                                <th>Server</th>
                                <th class="text-center">Qty</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var it in _lastOrderItems)
                            {
                                <tr>
                                    <td class="table-cell-wrap">@FormatPlayerToken(it.Key.Name)</td>
                                    <td class="table-cell-nowrap">@(it.Key.Server?.Name ?? "-")</td>
                                    <td class="text-center table-cell-nowrap">@it.Quantity</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
    else if (CartState.CartItems.Count == 0)
    {
        <div class="alert alert-info mt-4">
            <i class="bi bi-info-circle"></i> Your cart is empty. <button @onclick="ContinueShopping">Continue shopping</button>
        </div>
    }
    else
    {
        <div class="cart-total">
            @if (_appliedVoucher != null)
            {
                <span class="text-muted me-2" style="font-size:0.9em; text-decoration: line-through">€@CartTotal.ToString("F2")</span>
                <span class="text-success">€@FinalTotal.ToString("F2")</span>
            }
            else
            {
                <span>€@CartTotal.ToString("F2")</span>
            }
        </div>

        @* Voucher / Promo Code *@
        <div class="card mb-3">
            <div class="card-body">
                <h3 class="card-title mb-3">
                    Voucher
                </h3>
                @if (_appliedVoucher == null)
                {
                    <div>
                        <input type="text"
                                               class="form-control"
                                               placeholder="Enter voucher code"
                                               @bind="_voucherCode"
                                               @bind:event="oninput"
                                               @onkeydown="OnVoucherKeyDown" />
                        <button class="great-button"
                                @onclick="ApplyVoucherAsync"
                                disabled="@_voucherLoading">
                            @if (_voucherLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            }
                            Apply
                        </button>
                    </div>
                    @if (!string.IsNullOrEmpty(_voucherError))
                    {
                        <div class="mt-2 text-danger small">
                            <i class="bi bi-exclamation-circle me-1"></i>@_voucherError
                        </div>
                    }
                }
                else
                {
                    <div class="voucher-item">
                        <div>
                            <span>
                                <b>@_appliedVoucher.Code</b>
                            </span>
                            @* Show only the concise summary sentence instead of individual discount/applies-to lines *@
                            <div class="small text-success mt-1">@((!string.IsNullOrWhiteSpace(GetVoucherSummary(_appliedVoucher, _voucherAppliesTo))) ? GetVoucherSummary(_appliedVoucher, _voucherAppliesTo) : (_appliedVoucher.Message ?? "Discount applied"))</div>
                        </div>
                        <button class="danger" @onclick="RemoveVoucher">
                            <i class="bi bi-x-circle me-1"></i> Remove
                        </button>
                    </div>
                }
            </div>
        </div>

        <div class="card mt-4">
            <div class="card-body">
                <h2 class="card-title">Order summary</h2>
                <div class="table-wrapper">
                    <table class="table table-sm mt-3">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Server</th>
                                <th class="text-center">Qty</th>
                                <th class="text-end">Unit</th>
                                <th class="text-end">In Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in CartState.CartItems)
                            {
                                var p = item.Key;
                                var qty = item.Quantity;
                                double unitPrice = p.Sale > 0 ? Convert.ToDouble(p.Price) * (1 - p.Sale / 100.0) : Convert.ToDouble(p.Price);
                                <tr>
                                    <td class="table-cell-wrap">@FormatPlayerToken(p.Name)</td>
                                    <td class="table-cell-nowrap">@(p.Server?.Name ?? "-")</td>
                                    <td class="text-center table-cell-nowrap">@qty</td>
                                    <td class="text-end table-cell-nowrap">€@unitPrice.ToString("F2")</td>
                                    <td class="text-end table-cell-nowrap">€@((unitPrice * qty).ToString("F2"))</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <h2 class="mt-3">Server status</h2>
                @if (!_statusChecked)
                {
                    <div class="small text-muted">Checking server status...</div>
                }
                else if (_cartServers.Count == 0)
                {
                    <div class="small d-flex align-items-center gap-2 py-1" style="color:#44ae44;">
                        <i class="bi bi-circle-fill"></i>
                        <span>All servers are ready.</span>
                    </div>
                }
                else
                {
                    <ul class="list-unstyled mt-2" style="list-style-type: none;">
                        @foreach (var srv in _cartServers)
                        {
                            <li class="d-flex align-items-center gap-2 py-1">
                                <i class="bi bi-circle-fill" style="color: #@(_serverOnline ? "44ae44" : "dc3545")"></i>
                                <span class="me-2">@srv.Name</span>
                                <small style="margin-left: 5px;" class="text-muted">@(_serverOnline ? "Server is ready." : "Server is offline")</small>
                            </li>
                        }
                    </ul>
                }

                @if (_purchaseLimitErrors.Count > 0)
                {
                    <div class="alert alert-danger mt-3">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <strong>Purchase Limit Exceeded</strong>
                        <div class="mt-2">
                            @foreach (var error in _purchaseLimitErrors.Values)
                            {
                                <div>• @error</div>
                            }
                        </div>
                    </div>
                }

                <h2 class="mt-3">Choose payment method</h2>
                @if (_paymentsDisabled)
                {
                    <div class="alert alert-warning mt-3">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <strong>Payments are temporarily disabled</strong>
                        <div class="mt-2">All payment methods are currently unavailable. Please check back later.</div>
                    </div>
                }
                else
                {
                    <div class="mt-2">
                        <div class="payment-options d-flex flex-wrap gap-2">
                            @if (!_stripeDisabled)
                            {
                                <div class="payment-option @( _selectedPayment=="stripe" ? "selected" : "")" role="button" @onclick="SelectStripe">
                                    <div class="d-flex align-items-center gap-2">
                                        <i class="bi bi-bank fs-3"></i>
                                        <div>
                                            <strong>Stripe</strong>
                                            <div class="small text-muted">You will be redirected to the payment gateway. After successful payment, your items will be delivered to your account automatically. Available payment methods include <b>credit/debit card (Google Pay, Apple Pay, etc.), Bancontact, Multibanco, MobilePay, Klarna, Revolut Pay, and EPS</b>. Sorry, Apple Pay is not supported.</div>
                                        </div>
                                    </div>
                                </div>
                            }
                            @if (!_payPalDisabled)
                            {
                                <div class="payment-option @( _selectedPayment=="paypal" ? "selected" : "")" role="button" @onclick="SelectPaypal">
                                    <div class="d-flex align-items-center gap-2">
                                        <i class="bi bi-paypal fs-3"></i>
                                        <div>
                                            <strong>PayPal</strong>
                                            <div class="small text-muted">You will be redirected to the payment gateway. After successful payment, your items will be delivered to your account automatically. You can choose to pay either with your <b>PayPal account or with a debit card via PayPal</b>.</div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    @if (_stripeDisabled && _payPalDisabled)
                    {
                        <div class="alert alert-warning mt-3">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <strong>No payment methods available</strong>
                            <div class="mt-2">All payment methods are currently disabled. Please contact support.</div>
                        </div>
                    }
                }

                <div class="mt-4 d-flex gap-2">
                    <button class="great-button" @onclick="ProceedToPayment" disabled="@(!_canProceedToPayment || _paymentsDisabled || (_stripeDisabled && _payPalDisabled) || _purchaseLimitErrors.Count > 0)">Proceed to payment</button></div>

                @if (_cartServers.Count > 0 && !_serverOnline && _statusChecked)
                {
                    <div class="alert alert-warning mt-2">
                        The server is currently offline. Your items may not be delivered automatically after purchase.
                    </div>
                }

                @if (_showPaymentCard)
                {
                    @if (_selectedPayment == "paypal")
                    {
                        <div class="mt-3">
                            <div id="paypal-button-container"></div>
                            <div class="mt-2">
                                <button class="btn btn-outline-secondary" @onclick="CancelPayment">Cancel</button>
                            </div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(_payPalErrorMessage))
                        {
                            <div class="alert alert-danger mt-2">PayPal error: @_payPalErrorMessage</div>
                        }
                    }
                }

                @if (!string.IsNullOrWhiteSpace(_failureMessage))
                {
                    <div class="alert alert-danger mt-3">
                        <i class="bi bi-x-circle"></i> @_failureMessage
                        <div class="mt-2">
                            @if (_failureMessage.Contains("cancelled"))
                            {
                                <button class="btn btn-sm btn-primary" @onclick="ProceedToPayment">Try payment again</button>
                            }
                            else
                            {
                                <button @onclick="ContinueShopping">Continue shopping</button>
                            }
                        </div>
                    </div>
                }

            </div>
        </div>


@code {
    private const string VoucherStorageKey = "applied_voucher";

    private string _selectedPayment = "stripe";
    private bool _showPaymentCard = false;
    private bool _paymentSucceeded = false;
    private string _amount = ""; // default amount (start empty; cart total will prefill if available)
    private string? _successMessage;
    private string? _failureMessage;
    private bool _statusChecked = false;
    private bool _serverOnline = false;
    private List<SentrySMP.Shared.DTOs.ServerResponse> _cartServers = new();
    private bool _canProceedToPayment = false; // enabled only when server is online
    private PaymentSettingsResponse? _paymentSettings;
    private bool _paymentsDisabled = false;
    private bool _stripeDisabled = false;
    private bool _payPalDisabled = false;
    private Dictionary<string, string> _purchaseLimitErrors = new();

    // Voucher state
    private string _voucherCode = string.Empty;
    private ValidateVoucherResponse? _appliedVoucher;
    private bool _voucherLoading = false;
    private string? _voucherError;
    // UI details for applied voucher
    private string? _voucherAppliesTo;
    private string? _voucherDescription;

    // computed totals
    private double CartTotal => CartState.CartItems.Sum(i =>
        (i.Key.Sale > 0 ? Convert.ToDouble(i.Key.Price) * (1 - i.Key.Sale / 100.0) : Convert.ToDouble(i.Key.Price)) * i.Quantity);

    private double FinalTotal => Math.Max(0, CartTotal - (double)(_appliedVoucher?.DiscountAmount ?? 0));

    protected override async Task OnInitializedAsync()
    {
        CartState.OnChange += HandleCartChanged;

        // Load payment settings first
        try
        {
            _paymentSettings = await SentryApi.GetPaymentSettingsAsync();
            if (_paymentSettings != null)
            {
                _paymentsDisabled = !_paymentSettings.EnablePayments;
                _stripeDisabled = _paymentSettings.DisableStripe;
                _payPalDisabled = _paymentSettings.DisablePayPal;

                // Auto-select first available payment method
                if (!_paymentsDisabled)
                {
                    if (!_stripeDisabled)
                    {
                        _selectedPayment = "stripe";
                    }
                    else if (!_payPalDisabled)
                    {
                        _selectedPayment = "paypal";
                    }
                }
            }
        }
        catch (Exception ex)
        {
            _logger?.LogWarning(ex, "Failed to load payment settings");
        }

        // Load cart from browser storage (important when arriving via redirect)
        try
        {
            await CartState.LoadFromStorageAsync(JS);
        }
        catch { }
        // Initial server availability check
        try { await CheckServerStatusAsync(); } catch { }

        // Prefill amount from cart total if we have items
        var total = CartState.CartItems.Sum(i => (i.Key.Sale > 0 ? Convert.ToDouble(i.Key.Price) * (1 - i.Key.Sale / 100.0) : Convert.ToDouble(i.Key.Price)) * i.Quantity);
        if (total > 0)
        {
            _amount = total.ToString("F2");
        }

        // Load username for UI token replacement
        try
        {
            var u = await UserService.GetUsernameAsync();
            _username = (u ?? string.Empty).Trim().Replace("\r", string.Empty).Replace("\n", string.Empty);
        }
        catch
        {
            _username = string.Empty;
        }
        // create a logger instance for this component
        try
        {
            _logger = LoggerFactory?.CreateLogger("Checkout");
        }
        catch { }

        // initialize from shared voucher state and subscribe
        VoucherState.OnChange += OnVoucherStateChanged;
        _appliedVoucher = VoucherState.AppliedVoucher;
        _voucherCode = VoucherState.VoucherCode ?? string.Empty;
        _voucherError = VoucherState.Error;
        _voucherLoading = VoucherState.IsLoading;

        // Validate cart limits
        try
        {
            await ValidateCartLimitsAsync();
        }
        catch (Exception ex)
        {
            _logger?.LogWarning(ex, "Failed to validate cart limits");
        }
    }

    public void Dispose()
    {
        CartState.OnChange -= HandleCartChanged;
        VoucherState.OnChange -= OnVoucherStateChanged;
    }

    private async void HandleCartChanged()
    {
        try { await CheckServerStatusAsync(); } catch { }
        try { await ValidateCartLimitsAsync(); } catch { }
        try { await ReevaluateVoucherAsync(); } catch { }
        try { await InvokeAsync(StateHasChanged); } catch { }
    }

    // Re-evaluate the currently applied voucher when the cart changes.
    // If there are no applicable items left, suppress the percent/amount so UI and payment amounts stay correct.
    private async Task ReevaluateVoucherAsync()
    {
        if (_appliedVoucher == null) return;

        try
        {
            var items = CartState.CartItems.Select(ci =>
            {
                double unitPrice = ci.Key.Sale > 0
                    ? Convert.ToDouble(ci.Key.Price) * (1 - ci.Key.Sale / 100.0)
                    : Convert.ToDouble(ci.Key.Price);
                return new VoucherCartItem
                {
                    Type = ci.Key.Type,
                    Id = ci.Key.Id,
                    Quantity = ci.Quantity,
                    UnitPrice = unitPrice
                };
            }).ToList();

            decimal applicableTotal = 0m;
            foreach (var it in items)
            {
                bool applies = (_appliedVoucher.Scope ?? "All") switch
                {
                    "All" => true,
                    "Category" => string.Equals(it.Type, _appliedVoucher.ScopeCategory, StringComparison.OrdinalIgnoreCase),
                    "Item" => string.Equals(it.Type, _appliedVoucher.ScopeCategory, StringComparison.OrdinalIgnoreCase) && it.Id == _appliedVoucher.ScopeItemId,
                    _ => false
                };

                if (applies)
                    applicableTotal += (decimal)(it.UnitPrice * it.Quantity);
            }

            if (applicableTotal <= 0)
            {
                _appliedVoucher.DiscountPercent = 0m;
                _appliedVoucher.DiscountAmount = 0m;
                _appliedVoucher.Message = "No applicable items in cart";
                _amount = CartTotal.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
            }
            else
            {
                // Recalculate discount amount based on remaining applicable items
                var dp = _appliedVoucher.DiscountPercent;
                var newAmt = Math.Round(applicableTotal * dp / 100m, 2);
                _appliedVoucher.DiscountAmount = newAmt;
                _amount = FinalTotal.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
            }
        }
        catch
        {
            // best-effort; don't break cart updates on errors
        }
    }

    private void SelectPayment(string method)
    {
        _selectedPayment = method;
    }

    private void SelectStripe()
    {
        _selectedPayment = "stripe";
    }

    private void SelectPaypal()
    {
        _selectedPayment = "paypal";
    }

    private void ContinueShopping()
    {
        NavigationManager.NavigateTo("/");
    }

    private async Task CopyTransactionId()
    {
        try
        {
            if (_lastTransactionId.HasValue)
            {
                await JS.InvokeVoidAsync("navigator.clipboard.writeText", _lastTransactionId.Value.ToString());
                _copyFeedback = "Transaction ID copied";
                StateHasChanged();
                await Task.Delay(2000);
                _copyFeedback = null;
                StateHasChanged();
            }
        }
        catch { }
    }

    private async Task CopyIssue()
    {
        try
        {
            var sb = new System.Text.StringBuilder();
            sb.AppendLine($"Transaction ID: {_lastTransactionId?.ToString() ?? "N/A"}");
            if (!string.IsNullOrWhiteSpace(_deliveryStatusMessage)) sb.AppendLine($"Delivery status: {_deliveryStatusMessage}");
            if (!string.IsNullOrWhiteSpace(_failureMessage)) sb.AppendLine($"Failure details: {_failureMessage}");
            sb.AppendLine("Items:");
            if (_lastOrderItems != null)
            {
                foreach (var it in _lastOrderItems)
                {
                    sb.AppendLine($"- {it.Key.Name} | Server: {it.Key.Server?.Name ?? "-"} | Qty: {it.Quantity}");
                }
            }
            var text = sb.ToString();
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
            _copyFeedback = "Full issue copied";
            StateHasChanged();
            await Task.Delay(2000);
            _copyFeedback = null;
            StateHasChanged();
        }
        catch
        {
            _copyFeedback = "Copy failed";
            try { StateHasChanged(); } catch { }
        }
    }

    private string? _copyFeedback;

    private async Task ProceedToPayment()
    {
        _paymentSucceeded = false;

        // If Stripe is selected, create a Checkout Session and immediately redirect the user to Stripe (no simulated UI)
        if (_selectedPayment == "stripe")
        {
            try
            {
                double parsedStripe = 0;
                // Prefer the discounted total when a voucher is applied; otherwise use the manually entered _amount.
                var formattedStripe = _appliedVoucher != null
                    ? FinalTotal.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)
                    : _amount;

                if (!double.TryParse(formattedStripe, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out parsedStripe) || parsedStripe <= 0)
                {
                    // Use FinalTotal as fallback so vouchers always affect Stripe amount
                    parsedStripe = FinalTotal;
                    formattedStripe = parsedStripe.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
                }

                var stripeResp = await CheckoutApi.CreateStripeSessionAsync(new CreateStripeSessionRequest { Amount = formattedStripe, Description = "SentrySMP purchase" });
                if (stripeResp == null || string.IsNullOrWhiteSpace(stripeResp.Url))
                {
                    _payPalErrorMessage = "Server did not return Stripe checkout URL.";
                    _failureMessage = "Payment failed — server did not return Stripe checkout URL.";
                    _showPaymentCard = true; // show error area
                }
                else
                {
                    NavigationManager.NavigateTo(stripeResp.Url, true);
                    return;
                }
            }
            catch (Exception ex)
            {
                _payPalErrorMessage = ex.Message;
                _failureMessage = "Payment failed — " + ex.Message;
                _showPaymentCard = true;
            }
        }

        // For PayPal and simulated flows show the payment card
        _showPaymentCard = true;

        if (_selectedPayment == "paypal")
        {
            // Server-side create-order + redirect flow (no frontend JS)
            try
            {
                // Prefer the discounted total when a voucher is applied; otherwise use the manually entered _amount.
                double parsed = 0;
                var formatted = _appliedVoucher != null
                    ? FinalTotal.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)
                    : _amount;

                if (!double.TryParse(formatted, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out parsed) || parsed <= 0)
                {
                    // Use FinalTotal as fallback so vouchers affect PayPal amount
                    parsed = FinalTotal;
                    formatted = parsed.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
                }

                try
                {
                    var resp = await CheckoutApi.CreateOrderAsync(new CreateOrderRequest { Amount = formatted });
                    if (resp == null || string.IsNullOrWhiteSpace(resp.ApproveUrl))
                    {
                        _payPalErrorMessage = "Server did not return approval URL.";
                        _failureMessage = "Payment failed — server did not return PayPal approval URL.";
                    }
                    else
                    {
                        // Redirect browser to PayPal approval URL (full page load)
                        NavigationManager.NavigateTo(resp.ApproveUrl, true);
                        return;
                    }
                }
                catch (Exception ex)
                {
                    _payPalErrorMessage = $"PayPal error: {ex.Message}";
                    _failureMessage = $"Payment failed — {ex.Message}";
                }
            }
            catch (Exception ex)
            {
                _payPalErrorMessage = ex.Message;
                _failureMessage = "Payment failed — " + ex.Message;
            }
        }
    }

    private async Task CheckServerStatusAsync()
    {
        // Collect unique servers from cart items
        _cartServers = CartState.CartItems
            .Where(ci => ci.Key?.Server != null)
            .Select(ci => ci.Key.Server!)
            .GroupBy(s => s.Id)
            .Select(g => g.First())
            .ToList();

        // If no items require a server (e.g. rank-only cart), skip the online check entirely.
        if (_cartServers.Count == 0)
        {
            _statusChecked = true;
            _canProceedToPayment = true;
            return;
        }

        try
        {
            var players = await StatusService.GetMcPlayersAsync();
            _serverOnline = players.HasValue && players.Value > 5;
        }
        catch
        {
            _serverOnline = false;
        }
        _statusChecked = true;
        _canProceedToPayment = _serverOnline;
    }





