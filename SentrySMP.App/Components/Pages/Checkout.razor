    // Replace %player% tokens in UI strings with sanitized username
    private string FormatPlayerToken(string? text)
    {
        var user = _username ?? string.Empty;
        if (string.IsNullOrEmpty(text)) return string.Empty;
        try
        {
            return text.Replace("%player%", user, StringComparison.OrdinalIgnoreCase);
        }
        catch
        {
            return text ?? string.Empty;
        }
    }

    // Persist a payment transaction to the API. This is best-effort and does not block the UI on failure.
    private async Task SaveTransactionAsync(string provider, string providerTxId, List<CartItem>? items, string amount, string currency, string status)
    {
        try
        {
            // Snapshot the items immediately to avoid races with clearing the cart later
            var itemsSnapshot = (items ?? CartState.CartItems).Select(ci => new CartItem(ci.Key, ci.Quantity)).ToList();
            try { if (_logger != null) _logger.LogInformation("SaveTransactionAsync START provider={Provider} providerTxId={Tx} amountParam={Amount} itemsSnapshotCount={Count} hasRendered={HasRendered}", provider, providerTxId, amount, itemsSnapshot.Count, _hasRendered); } catch { }
            // Ensure amount is filled from cart if missing
            var computedAmount = amount;
            if (string.IsNullOrWhiteSpace(computedAmount) || computedAmount == "0" || computedAmount == "0.00")
            {
                var total = itemsSnapshot.Sum(i => (i.Key.Sale > 0 ? Convert.ToDouble(i.Key.Price) * (1 - i.Key.Sale / 100.0) : Convert.ToDouble(i.Key.Price)) * i.Quantity);
                computedAmount = total.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
                try { if (_logger != null) _logger.LogInformation("SaveTransactionAsync computedAmount from itemsSnapshot = {ComputedAmount} (itemsCount={Count})", computedAmount, itemsSnapshot.Count); } catch { }
            }
            // Serialize items in the server-expected shape so the TransactionsService
            // can deserialize into List<ProductQuantityDto> for RCON execution.
            var itemsForJson = itemsSnapshot.Select(i => new SentrySMP.Shared.DTOs.ProductQuantityDto
            {
                Product = i.Key,
                Quantity = i.Quantity
            }).ToList();

            var username = string.Empty;
            try
            {
                var u = await UserService.GetUsernameAsync();
                username = (u ?? string.Empty).Trim();
            }
            catch
            {
                username = string.Empty;
            }
            // Fallback to previously loaded username if available
            if (string.IsNullOrWhiteSpace(username) && !string.IsNullOrWhiteSpace(_username))
            {
                username = _username.Trim();
            }

            // Ensure amount is formatted using invariant culture (dot decimal) so server parsing (invariant) succeeds.
            try
            {
                if (!string.IsNullOrWhiteSpace(computedAmount))
                {
                    if (decimal.TryParse(computedAmount, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.CurrentCulture, out var parsedLocal))
                    {
                        computedAmount = parsedLocal.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
                    }
                    else if (decimal.TryParse(computedAmount.Replace(',', '.'), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var parsedAlt))
                    {
                        computedAmount = parsedAlt.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
                    }
                    // otherwise leave as-is; server will try to parse and may fallback
                }
            }
            catch { }

            var req = new SentrySMP.Shared.DTOs.CreateTransactionRequest
            {
                Provider = provider,
                ProviderTransactionId = providerTxId,
                Amount = computedAmount,
                Currency = currency ?? "EUR",
                MinecraftUsername = username,
                ItemsJson = JsonSerializer.Serialize(itemsForJson, new System.Text.Json.JsonSerializerOptions(System.Text.Json.JsonSerializerDefaults.Web)),
                Status = status ?? string.Empty,
                RawResponse = string.Empty
            };

            // Call server-side transactions service directly (runs on server; avoids HTTP roundtrip)
            try
            {
                try { _logger?.LogInformation("SaveTransactionAsync calling CreateTransactionAsync provider={Provider} amount={Amount} itemsCount={Count} itemsJson={ItemsJson}", req.Provider, req.Amount, itemsForJson?.Count ?? 0, req.ItemsJson?.Length); } catch { }
                var tx = await TransactionsService.CreateTransactionAsync(req);
                        if (tx != null)
                    {
                        // Remember whether the amount we saved was zero — used to avoid clearing cart
                        try
                        {
                            if (decimal.TryParse(req.Amount, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var a))
                            {
                                _lastTransactionAmountIsZero = a == 0m;
                            }
                            else
                            {
                                _lastTransactionAmountIsZero = false;
                            }
                        }
                        catch { _lastTransactionAmountIsZero = false; }
                        _lastTransactionId = tx.Id;
                            _successMessage = $"Payment received — thank you! (ID: {tx.Id})";

                        // After the transaction is saved, attempt to deliver commands for the purchased items.
                        try
                        {
                            var user = string.Empty;
                            try
                            {
                                user = await UserService.GetUsernameAsync() ?? string.Empty;
                            }
                            catch { user = string.Empty; }

                            var execProducts = itemsSnapshot.Select(ci => new ProductQuantityDto { Product = ci.Key, Quantity = ci.Quantity }).ToList();
                            if (!_hasRendered)
                            {
                                // Defer delivery execution until after the first render completes to ensure the component
                                // and related services (e.g. UserService, JS interop) are fully ready.
                                _pendingDeliveryProducts = execProducts;
                                _pendingDeliveryUsername = user;
                                _pendingVoucherCode = _appliedVoucher?.Code;
                                _pendingFinalTotal = FinalTotal;
                            }
                            else
                            {
                                try
                                {
                                    _logger?.LogInformation("Enqueuing delivery job for tx {TxId} (products={Count})", _lastTransactionId, execProducts?.Count ?? 0);
                                    var capturedVoucherCode = _appliedVoucher?.Code;
                                    var capturedFinalTotal = FinalTotal;
                                    var capturedTransactionId = _lastTransactionId;
                                    BackgroundQueue.QueueBackgroundWorkItem(async token =>
                                    {
                                        try
                                        {
                                            _logger?.LogInformation("Background delivery job starting for tx {TxId}", capturedTransactionId);
                                            var rres = await ExecuteDeliveryWithRetries(execProducts, user, capturedVoucherCode, capturedFinalTotal, capturedTransactionId);
                                            await InvokeAsync(async () =>
                                            {
                                                _deliveryResult = rres;
                                                if (rres != null) ProcessDeliveryResult(rres);
                                                StateHasChanged();
                                                // If we were deferring cart clear until delivery succeeded, clear now on success
                                                try
                                                {
                                                                                if (_clearCartOnDeliverySuccess && rres != null && rres.AllSucceeded)
                                                                                {
                                                                                    var isZero = await LastTransactionAmountIsZeroAsync();
                                                                                    if (isZero)
                                                                                    {
                                                                                        _logger?.LogWarning("Not clearing cart for tx {TxId} because saved amount was zero; triggering full reload", _lastTransactionId);
                                                                                        try
                                                                                        {
                                                                                            await JS.InvokeVoidAsync("location.reload", true);
                                                                                        }
                                                                                        catch (Exception exReload)
                                                                                        {
                                                                                            _logger?.LogWarning(exReload, "Failed to reload page after zero-amount tx {TxId}", _lastTransactionId);
                                                                                        }
                                                                                        _clearCartOnDeliverySuccess = false;
                                                                                        StateHasChanged();
                                                                                    }
                                                                                    else
                                                                                    {
                                                                                        _logger?.LogInformation("Delivery succeeded for tx {TxId}, recording purchases and clearing cart", _lastTransactionId);
                                                                                        // Record purchases for each item
                                                                                        try
                                                                                        {
                                                                                            foreach (var product in execProducts)
                                                                                            {
                                                                                                await PurchaseTrackingService.RecordPurchaseAsync(user, product.Product.Type, product.Product.Id, product.Quantity);
                                                                                            }
                                                                                            _logger?.LogInformation("Purchases recorded for tx {TxId}", _lastTransactionId);
                                                                                        }
                                                                                        catch (Exception exRecord)
                                                                                        {
                                                                                            _logger?.LogWarning(exRecord, "Failed to record purchases for tx {TxId}", _lastTransactionId);
                                                                                        }
                                                                                        await CartState.ClearCartAsync();
                                                                                        try { await VoucherState.RemoveAsync(); } catch { }
                                                                                        _clearCartOnDeliverySuccess = false;
                                                                                        StateHasChanged();
                                                                                    }
                                                                                }
                                                }
                                                catch (Exception exClear)
                                                {
                                                    _logger?.LogWarning(exClear, "Failed to clear cart after successful delivery for tx {TxId}", _lastTransactionId);
                                                }
                                            });
                                            _logger?.LogInformation("Background delivery job finished for tx {TxId}", capturedTransactionId);
                                        }
                                        catch (Exception exBackground)
                                        {
                                            _logger?.LogError(exBackground, "Background delivery job failed for tx {TxId}", capturedTransactionId);
                                            try { await InvokeAsync(() => { _failureMessage = _failureMessage ?? $"Warning: failed to execute server commands: {exBackground.Message}"; StateHasChanged(); }); } catch { }
                                        }
                                    });
                                }
                                catch (Exception exQueue)
                                {
                                    _logger?.LogError(exQueue, "Failed to enqueue delivery job for tx {TxId}", _lastTransactionId);
                                    _failureMessage = _failureMessage ?? $"Warning: failed to execute server commands: {exQueue.Message}";
                                }
                            }
                        }
                        catch (Exception ex)
                        {
                            // Best-effort: log and continue. UI should not fail the payment flow because of delivery problems.
                            _failureMessage = _failureMessage ?? $"Warning: failed to execute server commands: {ex.Message}";
                        }
                }
                else
                {
                    _successMessage = "Payment received — thank you! Your payment has been received.";
                }
            }
            catch (Exception ex)
            {
                _failureMessage = $"Failed to save the payment: {ex.Message}";
            }
        }
        catch (Exception ex)
        {
            _failureMessage = $"Error saving the payment: {ex.Message}";
            Console.WriteLine($"Failed to save transaction: {ex.Message}");
        }
        finally
        {
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Ensure cart is loaded from browser storage now that JS interop is available.
            try
            {
                // Only attempt if cart appears empty (avoid unnecessary JS call)
                if (CartState.CartItems == null || CartState.CartItems.Count == 0)
                {
                    try { _logger?.LogInformation("OnAfterRenderAsync: loading cart from localStorage"); } catch { }
                    await CartState.LoadFromStorageAsync(JS);
                }
            }
            catch (Exception exLoad)
            {
                try { _logger?.LogWarning(exLoad, "Failed to load cart from storage on first render"); } catch { }
            }

            // Auto-apply persisted voucher from localStorage (if any) and also honor querystring ?voucher=
            try
            {
                // Querystring param takes precedence over localStorage
                var uri = new Uri(NavigationManager.Uri);
                var qs = QueryHelpers.ParseQuery(uri.Query);
                string? voucherParam = null;
                if (qs.TryGetValue("voucher", out var v) && !string.IsNullOrWhiteSpace(v))
                {
                    voucherParam = v.ToString();
                }

                if (!string.IsNullOrWhiteSpace(voucherParam))
                {
                    _voucherCode = voucherParam!;
                    try { await VoucherState.ApplyAsync(_voucherCode, CartState, persist: true); } catch { }
                }
                else
                {
                    try { await VoucherState.LoadFromStorageAsync(CartState); } catch { }
                }
            }
            catch { }

            // Detect redirects from server-side PayPal return (e.g. ?status=success)
            var uri2 = new Uri(NavigationManager.Uri);
            var qs2 = QueryHelpers.ParseQuery(uri2.Query);
            if (qs2.TryGetValue("status", out var status))
            {
                if (status == "success")
                {
                    _wasRedirectStatusSuccess = true;
                    // Capture the items currently in the cart so we can render order details after clearing.
                    _lastOrderItems = CartState.CartItems.Select(ci => new CartItem(ci.Key, ci.Quantity)).ToList();

                    // Infer provider from querystring (Stripe returns session_id, PayPal returns orderId)
                    string providerName = "Manual";
                    string providerTxId = "return";
                    bool hasPaymentId = false;

                    if (!Env.IsProduction())
                    {
                        // Debug: skip provider/payment-ID inference — treat as a test payment so we can
                        // verify the full success flow without going through a real payment gateway.
                        providerName = "Debug";
                        providerTxId = $"debug-{DateTime.UtcNow:yyyyMMddHHmmss}";
                        hasPaymentId = true;
                    }
                    else
                    {
                        if (qs2.TryGetValue("session_id", out var sid) && !string.IsNullOrWhiteSpace(sid))
                        {
                            providerName = "Stripe";
                            providerTxId = sid.ToString();
                            hasPaymentId = true;
                        }
                        else if (qs2.TryGetValue("orderId", out var oid) && !string.IsNullOrWhiteSpace(oid))
                        {
                            providerName = "PayPal";
                            providerTxId = oid.ToString();
                            hasPaymentId = true;
                        }
                        else if (qs2.TryGetValue("provider", out var pv) && !string.IsNullOrWhiteSpace(pv))
                        {
                            // honor explicit provider if provided
                            providerName = pv.ToString();
                        }
                    }

                    // In production, reject the payment when no real payment ID was returned by the provider.
                    if (!hasPaymentId && Env.IsProduction())
                    {
                        _logger?.LogWarning("Payment return without payment ID rejected in production (uri={Uri})", NavigationManager.Uri);
                        _failureMessage = "Payment could not be confirmed — no payment ID was received. Please contact support if you were charged.";
                        _wasRedirectStatusSuccess = false;
                        StateHasChanged();
                        return;
                    }

                    // Persist transaction to API (best-effort)
                    try
                    {
                        await SaveTransactionAsync(providerName, providerTxId, _lastOrderItems, _amount, "EUR", "succeeded");
                    }
                    catch { }

                    try { _logger?.LogInformation("Clearing cart after provider return provider={Provider} tx={TxId} itemsCount={Count}", providerName, _lastTransactionId, CartState.CartItems.Count); } catch { }
                    {
                        var isZero = await LastTransactionAmountIsZeroAsync();
                        if (isZero)
                        {
                            try { _logger?.LogWarning("Not clearing cart after provider return for tx {TxId} because saved amount was zero; triggering full reload", _lastTransactionId); } catch { }
                            try
                            {
                                await JS.InvokeVoidAsync("location.reload", true);
                            }
                            catch (Exception exReload)
                            {
                                try { _logger?.LogWarning(exReload, "Failed to reload page after zero-amount tx {TxId}", _lastTransactionId); } catch { }
                            }
                        }
                        else
                        {
                            await CartState.ClearCartAsync();
                            try { await VoucherState.RemoveAsync(); } catch { }
                            try { _logger?.LogInformation("Cart cleared after provider return tx={TxId}", _lastTransactionId); } catch { }
                        }
                    }
                    _showPaymentCard = false;
                    _paymentSucceeded = true;
                    _successMessage = "Payment received — thank you! Your payment has been received.";
                    StateHasChanged();

                    // Record voucher usage if one was applied
                    if (_appliedVoucher != null && !string.IsNullOrWhiteSpace(_appliedVoucher.Code))
                    {
                        try
                        {
                            await SentryApi.RecordVoucherUsageAsync(new RecordVoucherUsageRequest
                            {
                                Code = _appliedVoucher.Code,
                                MinecraftUsername = _username ?? string.Empty
                            });
                        }
                        catch (Exception ex)
                        {
                            _logger?.LogWarning(ex, "Failed to record voucher usage for code {Code}", _appliedVoucher.Code);
                        }
                    }

                    // Note: we intentionally do not immediately remove the query string here so the success
                    // message can be shown after redirect. If you prefer the query removed, we can
                    // replace the history entry, but that will also re-initialize component state.
                }
                else if (status == "cancelled")
                {
                    // Show a user-friendly failure message when the payment was cancelled.
                    _failureMessage = "Payment cancelled. You can try the payment again.";
                    StateHasChanged();
                    // Keep the query string for this render so the message is visible; we won't replace the
                    // history entry here to remove it automatically.
                }
            }

            // Mark that first render completed and execute any deferred delivery requests.
            _hasRendered = true;
            if (_pendingDeliveryProducts != null)
            {
                try
                {
                    var rres = await ExecuteDeliveryWithRetries(_pendingDeliveryProducts, _pendingDeliveryUsername ?? string.Empty, _pendingVoucherCode, _pendingFinalTotal, _lastTransactionId);
                    _deliveryResult = rres;
                    if (rres != null)
                    {
                        ProcessDeliveryResult(rres);
                    }
                    // If we were deferring cart clear until delivery succeeded, clear now on success
                    try
                    {
                        if (_clearCartOnDeliverySuccess && rres != null && rres.AllSucceeded)
                        {
                            if (_lastTransactionAmountIsZero)
                            {
                                _logger?.LogWarning("Not clearing cart for tx {TxId} after deferred delivery because saved amount was zero; triggering full reload", _lastTransactionId);
                                try
                                {
                                    await JS.InvokeVoidAsync("location.reload", true);
                                }
                                catch (Exception exReload)
                                {
                                    _logger?.LogWarning(exReload, "Failed to reload page after zero-amount tx {TxId}", _lastTransactionId);
                                }
                                _clearCartOnDeliverySuccess = false;
                            }
                            else
                            {
                                _logger?.LogInformation("Deferred delivery succeeded for tx {TxId}, recording purchases and clearing cart", _lastTransactionId);
                                // Record purchases for each item
                                try
                                {
                                                    var user = _pendingDeliveryUsername ?? string.Empty;
                                    var products = _pendingDeliveryProducts ?? new List<ProductQuantityDto>();
                                    foreach (var product in products)
                                    {
                                        await PurchaseTrackingService.RecordPurchaseAsync(user, product.Product.Type, product.Product.Id, product.Quantity);
                                    }
                                    _logger?.LogInformation("Purchases recorded for deferred tx {TxId}", _lastTransactionId);
                                }
                                catch (Exception exRecord)
                                {
                                    _logger?.LogWarning(exRecord, "Failed to record purchases for deferred tx {TxId}", _lastTransactionId);
                                }
                                await CartState.ClearCartAsync();
                                try { await VoucherState.RemoveAsync(); } catch { }
                                _clearCartOnDeliverySuccess = false;
                            }
                        }
                    }
                    catch (Exception exClear)
                    {
                        _logger?.LogWarning(exClear, "Failed to clear cart after deferred successful delivery for tx {TxId}", _lastTransactionId);
                    }
                }
                catch (Exception ex)
                {
                    _failureMessage = _failureMessage ?? $"Warning: failed to execute server commands after render: {ex.Message}";
                }
                finally
                {
                    _pendingDeliveryProducts = null;
                    _pendingDeliveryUsername = null;
                    StateHasChanged();
                }
            }
            }
        }

    private async Task TryDeliveryAgainAsync()
    {
        if (_retryDeliveryInProgress) return;
        _retryDeliveryInProgress = true;
        _canRetryDelivery = false;
        _deliveryStatusMessage = null;
        StateHasChanged();

        try
        {
            var products = _lastOrderItems?.Select(ci => new ProductQuantityDto { Product = ci.Key, Quantity = ci.Quantity }).ToList();
            if (products == null || products.Count == 0)
            {
                _failureMessage = "No order items to retry.";
                return;
            }

            var user = string.Empty;
            try { user = await UserService.GetUsernameAsync() ?? string.Empty; } catch { }
            if (string.IsNullOrWhiteSpace(user)) user = _username ?? string.Empty;

            var rres = await RconService.ExecuteCommandsForProductsAsync(products, user, _appliedVoucher?.Code, null);
            _deliveryResult = rres;
            if (rres != null)
            {
                // ProcessDeliveryResult appends to _successMessage — preserve it during retries
                var savedSuccessMessage = _successMessage;
                ProcessDeliveryResult(rres);
                _successMessage = savedSuccessMessage;

                _retryDeliveryCount++;

                // Update transaction status to record the manual retry
                if (_lastTransactionId.HasValue)
                {
                    try { await TransactionsService.UpdateTransactionStatusAsync(_lastTransactionId.Value, "TRIED_AGAIN"); } catch { }
                }
                // If now all succeeded, clear the failure message
                var allOk = rres.CommandResults != null && rres.CommandResults.Count > 0 && rres.CommandResults.All(cr => cr.Succeeded);
                if (allOk) _failureMessage = null;
                // Allow another retry only if all remaining failures are still "not connected" and limit not reached
                var failedNow = rres.CommandResults?.Where(cr => !cr.Succeeded).ToList();
                _canRetryDelivery = _retryDeliveryCount < 2
                    && failedNow != null && failedNow.Count > 0 && failedNow.All(cr => IsPlayerNotConnectedResponse(cr));
            }
        }
        catch (Exception ex)
        {
            _failureMessage = $"Retry failed: {ex.Message}";
        }
        finally
        {
            _retryDeliveryInProgress = false;
            StateHasChanged();
        }
    }

    // Helper to centralize the delivery result processing so we can reuse it when executing immediately
    // or when executing a deferred request after OnAfterRenderAsync.
    private void ProcessDeliveryResult(SentrySMP.Shared.DTOs.RconExecutionResult rres)
    {
        // More robust evaluation: don't trust AllSucceeded alone.
        var hasNoCommandsMarker = rres.CommandResults != null && rres.CommandResults.Any(cr => cr.CommandText == "<NO_RCON_COMMANDS_FOUND>");
        var anyResults = rres.CommandResults != null && rres.CommandResults.Count > 0;
    var allSucceeded = anyResults && rres.CommandResults != null && rres.CommandResults.All(cr => cr.Succeeded) && !hasNoCommandsMarker;

        if (hasNoCommandsMarker)
        {
            _deliveryStatusMessage = "No server commands were defined for the purchased products.";
            _failureMessage = _failureMessage ?? "Warning: no server commands were configured for your purchase.";
        }
        else if (allSucceeded)
        {
            _deliveryStatusMessage = "Server commands were successfully sent.";
        }
        else
        {
            _deliveryStatusMessage = "Some commands failed to send:";
            // also set a visible failure message area
            _failureMessage = _failureMessage ?? "Warning: some server commands failed. Details below.";
        }

        // Append delivery status to the success message so it remains visible together with the paid message.
        if (!string.IsNullOrWhiteSpace(_deliveryStatusMessage))
        {
            _successMessage = string.IsNullOrWhiteSpace(_successMessage)
                ? _deliveryStatusMessage
                : _successMessage + " — " + _deliveryStatusMessage;
        }

        // Show "Try Again" button only when ALL failures are player-not-connected.
        var failedCmds = rres.CommandResults?.Where(cr => !cr.Succeeded).ToList();
        _canRetryDelivery = failedCmds != null && failedCmds.Count > 0 && failedCmds.All(cr => IsPlayerNotConnectedResponse(cr));
    }

    // Returns true when the RCON response/error indicates the player is not currently connected to the server.
    private static bool IsPlayerNotConnectedResponse(SentrySMP.Shared.DTOs.RconCommandResult cr)
    {
        var text = (cr.Response ?? cr.ErrorMessage ?? string.Empty);
        return text.IndexOf("is not connected", StringComparison.OrdinalIgnoreCase) >= 0
            || text.IndexOf("is not online", StringComparison.OrdinalIgnoreCase) >= 0;
    }

    // Execute delivery commands.
    // Only retries once — and only when ALL failures are "player not connected" responses.
    // After the retry the existing transaction is updated to include "TRIED_AGAIN" in its status.
    // Other errors are returned immediately without retrying.
    // Returns the final RconExecutionResult (may contain failed commands) or null if execution could not be attempted.
    private async Task<SentrySMP.Shared.DTOs.RconExecutionResult?> ExecuteDeliveryWithRetries(List<ProductQuantityDto> products, string user, string? voucherCode = null, double? paidAmount = null, long? transactionId = null)
    {
        if (products == null || products.Count == 0) return null;

        SentrySMP.Shared.DTOs.RconExecutionResult? rres = null;
        try
        {
            rres = await RconService.ExecuteCommandsForProductsAsync(products, user, voucherCode, paidAmount);
        }
        catch (Exception ex)
        {
            _logger?.LogError(ex, "Delivery execution failed for tx {TxId}", transactionId);
            return null;
        }

        if (rres == null) return null;

        var hasNoCommandsMarker = rres.CommandResults != null && rres.CommandResults.Any(cr => cr.CommandText == "<NO_RCON_COMMANDS_FOUND>");
        if (hasNoCommandsMarker) return rres;

        // Check if ALL failures are "player not connected" — only then allow one retry.
        var failedResults = rres.CommandResults?.Where(cr => !cr.Succeeded).ToList();
        if (failedResults == null || !failedResults.Any()) return rres;

        bool allFailsAreNotConnected = failedResults.All(cr => IsPlayerNotConnectedResponse(cr));
        if (!allFailsAreNotConnected)
        {
            // Other error types — no retry allowed.
            return rres;
        }

        // One retry for "player not connected" (player may just be logging in).
        _logger?.LogInformation("Retrying delivery for tx {TxId} — all failures are player-not-connected", transactionId);
        await Task.Delay(2000);

        SentrySMP.Shared.DTOs.RconExecutionResult? retryRres = null;
        try
        {
            retryRres = await RconService.ExecuteCommandsForProductsAsync(products, user, voucherCode, paidAmount);
        }
        catch (Exception ex)
        {
            _logger?.LogError(ex, "Delivery retry failed for tx {TxId}", transactionId);
            retryRres = rres;
        }

        // Mark the transaction to record that a retry was attempted.
        if (transactionId.HasValue)
        {
            try
            {
                await TransactionsService.UpdateTransactionStatusAsync(transactionId.Value, "TRIED_AGAIN");
            }
            catch (Exception ex)
            {
                _logger?.LogWarning(ex, "Failed to update tx {TxId} status to TRIED_AGAIN", transactionId.Value);
            }
        }

        return retryRres ?? rres;
    }

    // Truncate long strings for compact UI rendering (compact version that strips color/control codes)
    private string TruncateCompact(string? s, int maxLen = 60)
    {
        if (string.IsNullOrEmpty(s)) return string.Empty;
        try
        {
            // Remove Minecraft-style formatting codes like '§a' and long sequences like '§x§f§f§e...'
            var withoutCodes = System.Text.RegularExpressions.Regex.Replace(s, "§.", string.Empty);
            // Collapse whitespace/newlines so the text fits in a single table cell
            var singleLine = System.Text.RegularExpressions.Regex.Replace(withoutCodes, "\r\n|\n|\r", " ");
            singleLine = System.Text.RegularExpressions.Regex.Replace(singleLine, "\t| {2,}|\\s+", " ").Trim();
            if (singleLine.Length <= maxLen) return singleLine;
            return singleLine.Substring(0, maxLen) + "...";
        }
        catch
        {
            return s ?? string.Empty;
        }
    }

    // Clean a response into a single-line string without truncation (keeps full length but collapses formatting)
    private string CleanSingleLine(string? s)
    {
        if (string.IsNullOrEmpty(s)) return string.Empty;
        try
        {
            // remove Minecraft-style formatting codes like '§a'
            var withoutCodes = System.Text.RegularExpressions.Regex.Replace(s, "§.", string.Empty);
            // keep only Unicode letters (remove digits, punctuation, whitespace, etc.)
            var lettersOnly = System.Text.RegularExpressions.Regex.Replace(withoutCodes, @"[^\p{L}]", string.Empty);
            const int maxChars = 9; // length before adding ellipsis
            if (lettersOnly.Length <= maxChars) return lettersOnly;
            return lettersOnly.Substring(0, maxChars) + "...";
        }
        catch
        {
            return s ?? string.Empty;
        }
    }

    // Backwards-compatible simple Truncate wrapper (keeps original behavior if used elsewhere)
    private string Truncate(string? s, int maxLen = 120) => TruncateCompact(s, maxLen);

    // Read the persisted transaction to determine whether the saved amount was zero.
    private async Task<bool> LastTransactionAmountIsZeroAsync()
    {
        try
        {
            if (!_lastTransactionId.HasValue) return false;
            var tx = await TransactionsService.GetTransactionAsync(_lastTransactionId.Value);
            if (tx == null) return false;
            return tx.Amount == 0m;
        }
        catch
        {
            return false;
        }
    }

    // Validate cart against GlobalMaxOrder limits
    private async Task ValidateCartLimitsAsync()
    {
        _purchaseLimitErrors.Clear();

        try
        {
            var username = await UserService.GetUsernameAsync();
            if (string.IsNullOrWhiteSpace(username))
                return;

            var cartData = CartState.CartItems
                .Select(ci => (ci.Key, ci.Quantity))
                .ToList();

            _purchaseLimitErrors = await PurchaseTrackingService.ValidateCartLimitsAsync(username, cartData);
        }
        catch (Exception ex)
        {
            _logger?.LogError(ex, "Failed to validate cart limits");
        }

        StateHasChanged();
    }

    private async Task OnVoucherKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e?.Key == "Enter")
        {
            await ApplyVoucherAsync();
        }
    }

    private async Task ApplyVoucherAsync()
    {
        _voucherError = null;
        _appliedVoucher = null;
        var code = _voucherCode.Trim();
        if (string.IsNullOrWhiteSpace(code)) { _voucherError = "Please enter a voucher code."; return; }

        _voucherLoading = true;
        StateHasChanged();
        try
        {
            await VoucherState.ApplyAsync(code, CartState, persist: true);
            // copy results into local view
            _appliedVoucher = VoucherState.AppliedVoucher;
            _voucherError = VoucherState.Error;
            _voucherLoading = VoucherState.IsLoading;
            if (_appliedVoucher != null)
            {
                try { await LoadVoucherDetailsAsync(_appliedVoucher); } catch { }
                _amount = FinalTotal.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
            }
        }
        catch (Exception ex)
        {
            _voucherError = $"Error applying voucher: {ex.Message}";
            _logger?.LogError(ex, "Error applying voucher code {Code}", code);
        }
        finally
        {
            _voucherLoading = false;
            StateHasChanged();
        }
    }

    private async Task RemoveVoucher()
    {
        await VoucherState.RemoveAsync();
        _appliedVoucher = null;
        _voucherCode = string.Empty;
        _voucherError = null;
        _voucherAppliesTo = null;
        _voucherDescription = null;
        // Restore original amount
        _amount = CartTotal.ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
    }

    private async Task LoadVoucherDetailsAsync(ValidateVoucherResponse resp)
    {
        _voucherAppliesTo = null;
        _voucherDescription = resp.Message;

        try
        {
            var scope = resp.Scope ?? "All";
            if (scope.Equals("All", StringComparison.OrdinalIgnoreCase))
            {
                _voucherAppliesTo = "All items";
            }
            else if (scope.Equals("Category", StringComparison.OrdinalIgnoreCase))
            {
                _voucherAppliesTo = resp.ScopeCategory ?? "Category";
            }
            else if (scope.Equals("Item", StringComparison.OrdinalIgnoreCase) && resp.ScopeItemId.HasValue)
            {
                var id = resp.ScopeItemId.Value;
                var cat = resp.ScopeCategory ?? string.Empty;
                try
                {
                    switch (cat)
                    {
                        case "Key":
                            var key = await SentryApi.GetKeyAsync(id);
                            _voucherAppliesTo = key?.Name ?? ($"{cat} #{id}");
                            break;
                        case "Rank":
                            var rank = await SentryApi.GetRankAsync(id);
                            _voucherAppliesTo = rank?.Name ?? ($"{cat} #{id}");
                            break;
                        case "Bundle":
                            var bundle = await SentryApi.GetBundleAsync(id);
                            _voucherAppliesTo = bundle?.Name ?? ($"{cat} #{id}");
                            break;
                        case "Coin":
                            var coin = await SentryApi.GetCoinAsync(id);
                            _voucherAppliesTo = coin?.Name ?? ($"{cat} #{id}");
                            break;
                        case "Other":
                            var other = await SentryApi.GetOtherAsync(id);
                            _voucherAppliesTo = other?.Name ?? ($"{cat} #{id}");
                            break;
                        case "BattlePass":
                            var bp = await SentryApi.GetBattlePassAsync(id);
                            _voucherAppliesTo = bp?.Name ?? ($"{cat} #{id}");
                            break;
                        default:
                            _voucherAppliesTo = $"{cat} #{id}";
                            break;
                    }
                }
                catch
                {
                    _voucherAppliesTo = $"{cat} #{id}";
                }
            }

            // Try to fetch a richer description from voucher list if available
            try
            {
                var list = await SentryApi.GetVouchersAsync();
                var found = list?.FirstOrDefault(v => string.Equals(v.Code, resp.Code, StringComparison.OrdinalIgnoreCase));
                if (found != null && !string.IsNullOrWhiteSpace(found.Description))
                {
                    _voucherDescription = found.Description;
                }
            }
            catch { }
        }
        catch { }

        StateHasChanged();
    }

    private void OnVoucherStateChanged()
    {
        _appliedVoucher = VoucherState.AppliedVoucher;
        _voucherCode = VoucherState.VoucherCode ?? string.Empty;
        _voucherError = VoucherState.Error;
        _voucherLoading = VoucherState.IsLoading;
        try { InvokeAsync(StateHasChanged); } catch { }
    }

    private string GetVoucherSummary(ValidateVoucherResponse v, string? appliesTo)
    {
        if (v == null) return string.Empty;
        // Human-readable scope text; prefer appliesTo if provided
        var scopeRaw = (appliesTo ?? v.Scope ?? "all").ToString();
        string scopeText;
        if (string.Equals(v.Scope ?? string.Empty, "Category", StringComparison.OrdinalIgnoreCase))
        {
            var cat = (v.ScopeCategory ?? scopeRaw ?? "items").Trim();
            scopeText = PluralizeCategory(cat).ToLowerInvariant();
        }
        else
        {
            scopeText = scopeRaw;
        }

        try
        {
            var d = v.DiscountPercent;
            var isWhole = d == decimal.Truncate(d);
            if (d > 0)
            {
                var pctStr = isWhole ? ((int)d).ToString() : d.ToString("0.#");
                return $"{pctStr}% discount applied for {scopeText.ToLowerInvariant()}";
            }
        }
        catch { }

        if (v.DiscountAmount > 0)
        {
            return $"€{v.DiscountAmount:F2} off applied for {scopeText.ToLowerInvariant()}";
        }

        return v.Message ?? "Discount applied";
    }

    private string PluralizeCategory(string cat)
    {
        if (string.IsNullOrWhiteSpace(cat)) return "items";
        switch (cat.Trim())
        {
            case "Key": return "Keys";
            case "Rank": return "Ranks";
            case "Bundle": return "Bundles";
            case "Coin": return "Coins";
            case "Other": return "Others";
            case "BattlePass": return "BattlePasses";
            default:
                if (cat.EndsWith("y", StringComparison.OrdinalIgnoreCase))
                    return cat.Substring(0, cat.Length - 1) + "ies";
                return cat + "s";
        }
    }
