@page "/changelog"
@inject SentrySMP.Shared.Interfaces.IAnnouncementsService AnnouncementsService
@inject IHttpClientFactory HttpClientFactory
@rendermode InteractiveServer
@using System.Text.Json
@using System.Text.RegularExpressions

<PageTitle>Changelog - SentrySMP</PageTitle>

<div class="changelog-tabs">
    <button class="changelog-tab @(activeTab == "web" ? "active" : "")" @onclick='() => SwitchTab("web")'>
        <i class="bi bi-globe"></i> Web
    </button>
    <button class="changelog-tab @(activeTab == "server" ? "active" : "")" @onclick='() => SwitchTab("server")'>
        <i class="bi bi-server"></i> Server
    </button>
    <button class="changelog-tab @(activeTab == "sentryapi" ? "active" : "")" @onclick='() => SwitchTab("sentryapi")'>
        <i class="bi bi-plugin"></i> SentryAPI
    </button>
    <button class="changelog-tab @(activeTab == "sentrytiers" ? "active" : "")" @onclick='() => SwitchTab("sentrytiers")'>
        <i class="bi bi-gem"></i> SentryTiers
    </button>
</div>

