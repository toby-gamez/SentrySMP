else if (activeTab == "server")
{
    @if (serverLoading)
    {
        <p class="server-loading">Loading server changelog...</p>
    }
    else if (serverError != null)
    {
        <p class="error">@serverError</p>
    }
    else if (serverEntries?.Any() == true)
    {
        @foreach (var entry in serverEntries)
        {
            <div class="server-entry">
                <div class="server-entry-meta">
                    <i class="bi bi-calendar3"></i>
                    @entry.CreatedAt.ToLocalTime().ToString("d. MMMM yyyy", new System.Globalization.CultureInfo("cs-CZ"))
                    <span class="server-entry-time">@entry.CreatedAt.ToLocalTime().ToString("HH:mm")</span>
                </div>
                <div class="server-entry-content">@((MarkupString)entry.HtmlContent)</div>
            </div>
        }
    }
    else
    {
        <p style="color:#888">No server changelog entries found.</p>
    }
}

