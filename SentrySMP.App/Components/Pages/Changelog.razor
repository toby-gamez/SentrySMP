@code {
    private string activeTab = "web";

    private bool serverLoading = false;
    private bool serverLoaded = false;
    private string? serverError;
    private List<ServerEntryWithHtml>? serverEntries;

    private bool sentryApiLoading = false;
    private bool sentryApiLoaded = false;
    private string? sentryApiError;
    private List<SentryApiRelease>? sentryApiReleases;
    
    private bool sentryTiersLoading = false;
    private bool sentryTiersLoaded = false;
    private string? sentryTiersError;
    private List<SentryApiRelease>? sentryTiersReleases;

    private async Task SwitchTab(string tab)
    {
        activeTab = tab;
        StateHasChanged();
        if (tab == "server" && !serverLoaded)
            await LoadServerChangelog();
        else if (tab == "sentryapi" && !sentryApiLoaded)
            await LoadSentryApiReleases();
        else if (tab == "sentrytiers" && !sentryTiersLoaded)
            await LoadSentryTiersReleases();
    }

    private async Task LoadServerChangelog()
    {
        serverLoading = true;
        serverError = null;
        StateHasChanged();
        try
        {
            var res = (await AnnouncementsService.GetServerChangelogAsync()).ToList();
            var pipeline = new Markdig.MarkdownPipelineBuilder().Build();
            serverEntries = res.Select(r => new ServerEntryWithHtml
            {
                CreatedAt = r.CreatedAt,
                HtmlContent = Markdig.Markdown.ToHtml(r.Content ?? string.Empty, pipeline)
            }).ToList();
        }
        catch
        {
            serverError = "Failed to load server changelog from Discord.";
        }
        finally
        {
            serverLoading = false;
            serverLoaded = true;
            StateHasChanged();
        }
    }

    private async Task LoadSentryApiReleases()
    {
        sentryApiLoading = true;
        sentryApiError = null;
        StateHasChanged();
        try
        {
            var client = HttpClientFactory.CreateClient();
            client.DefaultRequestHeaders.UserAgent.ParseAdd("SentrySMP-Website/1.0");
            var resp = await client.GetAsync("https://api.github.com/repos/toby-gamez/SentryAPI/releases");
            if (!resp.IsSuccessStatusCode)
            {
                sentryApiError = "Failed to load SentryAPI releases from GitHub.";
                return;
            }
            var json = await resp.Content.ReadAsStringAsync();
            using var doc = JsonDocument.Parse(json);
            var pipeline = new Markdig.MarkdownPipelineBuilder().Build();
            var releases = new List<SentryApiRelease>();
            foreach (var item in doc.RootElement.EnumerateArray())
            {
                var tagName = item.TryGetProperty("tag_name", out var t) ? t.GetString() ?? "" : "";
                var publishedAt = item.TryGetProperty("published_at", out var p) && DateTime.TryParse(p.GetString(), out var dt) ? dt : DateTime.UtcNow;
                var body = item.TryGetProperty("body", out var b) ? b.GetString() ?? "" : "";
                // Remove first ## heading
                body = Regex.Replace(body, @"^##[^\n]*\n?", "", RegexOptions.None, TimeSpan.FromSeconds(1));
                releases.Add(new SentryApiRelease
                {
                    TagName = tagName,
                    PublishedAt = publishedAt,
                    HtmlContent = Markdig.Markdown.ToHtml(body, pipeline)
                });
            }
            sentryApiReleases = releases;
        }
        catch
        {
            sentryApiError = "Failed to load SentryAPI releases from GitHub.";
        }
        finally
        {
            sentryApiLoading = false;
            sentryApiLoaded = true;
            StateHasChanged();
        }
    }

    private async Task LoadSentryTiersReleases()
    {
        sentryTiersLoading = true;
        sentryTiersError = null;
        StateHasChanged();
        try
        {
            var client = HttpClientFactory.CreateClient();
            client.DefaultRequestHeaders.UserAgent.ParseAdd("SentrySMP-Website/1.0");
            var resp = await client.GetAsync("https://api.github.com/repos/toby-gamez/SentryTiers/releases");
            if (!resp.IsSuccessStatusCode)
            {
                sentryTiersError = "Failed to load SentryTiers releases from GitHub.";
                return;
            }
            var json = await resp.Content.ReadAsStringAsync();
            using var doc = JsonDocument.Parse(json);
            var pipeline = new Markdig.MarkdownPipelineBuilder().Build();
            var releases = new List<SentryApiRelease>();
            foreach (var item in doc.RootElement.EnumerateArray())
            {
                var tagName = item.TryGetProperty("tag_name", out var t) ? t.GetString() ?? "" : "";
                var publishedAt = item.TryGetProperty("published_at", out var p) && DateTime.TryParse(p.GetString(), out var dt) ? dt : DateTime.UtcNow;
                var body = item.TryGetProperty("body", out var b) ? b.GetString() ?? "" : "";
                body = Regex.Replace(body, @"^##[^\n]*\n?", "", RegexOptions.None, TimeSpan.FromSeconds(1));
                releases.Add(new SentryApiRelease
                {
                    TagName = tagName,
                    PublishedAt = publishedAt,
                    HtmlContent = Markdig.Markdown.ToHtml(body, pipeline)
                });
            }
            sentryTiersReleases = releases;
        }
        catch
        {
            sentryTiersError = "Failed to load SentryTiers releases from GitHub.";
        }
        finally
        {
            sentryTiersLoading = false;
            sentryTiersLoaded = true;
            StateHasChanged();
        }
    }

    private class ServerEntryWithHtml
    {
        public DateTime CreatedAt { get; init; }
        public string HtmlContent { get; init; } = string.Empty;
    }

    private class SentryApiRelease
    {
        public string TagName { get; init; } = string.Empty;
        public DateTime PublishedAt { get; init; }
        public string HtmlContent { get; init; } = string.Empty;
    }
}
