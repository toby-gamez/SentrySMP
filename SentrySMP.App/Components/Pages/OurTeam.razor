@page "/our-team"
@attribute [StreamRendering]
@using SentrySMP.Shared.DTOs
@rendermode InteractiveServer
@inject SentrySMP.Shared.Interfaces.ISentryApi Api
<PageTitle>Our Team - SentrySMP</PageTitle>

<style>
    .container {
        max-width: 1200px;
    }
</style>

<div class="main-wrapper">
    <h1 class="main">Our Team</h1>
</div>

@if (team == null)
{
    <p><em>Loading...</em></p>
}
else if (!team.Categories.Any())
{
    <p><em>No team members configured yet.</em></p>
}
else
{
        @foreach (var cat in team.Categories)
        {
            <div class="section">
                <h2 class="section-title">@cat.Name</h2>
                    <div class="team-grid">
                    @foreach (var m in cat.Members)
                    {
                            <div class="team-item">
                                <div class="avatar">
                                    <img src="@GetSkinUrl(m)" class="skin-preview" alt="@m.MinecraftName" width="75px" height="75px"/>
                                </div>
                                <h5 class="person">@m.MinecraftName</h5>
                                @if (m.Rank != null)
                                {
                                    <span class="role-badge badge" style="background-color: @(string.IsNullOrWhiteSpace(m.Rank.HexColor) ? "#666" : m.Rank.HexColor)">@(m.Rank.Name)</span>
                                }
                            </div>
                    }
                    </div>
            </div>
        }
}

@code {
    private TeamResponseDto? team;
    private string? loadError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            team = await Api.GetTeamAsync();
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
            team = new TeamResponseDto();
        }
    }

    private string GetSkinUrl(TeamMemberDto member)
    {
        if (!string.IsNullOrEmpty(member.SkinUrl)) return member.SkinUrl!;
        var name = string.IsNullOrWhiteSpace(member.MinecraftName) ? "steve" : member.MinecraftName;
        return $"https://minotar.net/helm/{Uri.EscapeDataString(name)}/100";
    }

    // role class helper removed; badges now use Rank.HexColor
}
