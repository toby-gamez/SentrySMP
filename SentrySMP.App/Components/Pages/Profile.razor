@page "/profile"
@page "/profile/{Name}"
@using SentrySMP.Shared.DTOs
@inject SentrySMP.App.Authentication.UserService UserService
@inject SentrySMP.Shared.Interfaces.IGameServerService GameServerService
@inject SentrySMP.Shared.Interfaces.ITeamRankService TeamRankService
@inject SentrySMP.Shared.Interfaces.ITransactionsService TransactionsService
@inject SentrySMP.Shared.Interfaces.IShopScoreboardService ShopScoreboardService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Profile - SentrySMP</PageTitle>

@if (!_loaded)
{
    <div>Loading profile...</div>
}
else if (!_loggedIn)
{
    <div class="login-card" style="max-width:480px;">
        <div class="login-skin-panel">
            <img src="https://minotar.net/helm/MHF_Steve/100" alt="Skin preview" class="login-skin-img" />
            <div class="login-skin-name">Minecraft Player</div>
            <div class="login-skin-badge">Not logged in</div>
        </div>
        <div class="login-form-panel">
            <p style="color:#9e9e9e;margin:0;">You must be logged in to view your profile.</p>
            <div class="login-actions">
                <button class="great-button" @onclick="GoLogin">Log in</button>
            </div>
        </div>
    </div>
}
else
{
    
    <div class="login-card profile-card">
        <!-- Left: skin panel -->
        <div class="login-card-inner">
        <div class="login-skin-panel">
            <img src="@(_skinUrl ?? "https://minotar.net/helm/MHF_Steve/100")" alt="Skin preview" />
            <div class="login-skin-name">@_username</div>
            @if (!string.IsNullOrWhiteSpace(_rankName))
            {
                <div class="login-skin-badge" style="background:@(_rankHex ?? "#444"); color:#fff;">@_rankName</div>
            }
            else
            {
                <div class="login-skin-badge">Player</div>
            }
        </div>

        <!-- Right: stats panel -->
        <div class="login-form-panel">
            <div class="profile-stats">
                @if (_isOnline)
                {
                    <div class="profile-stat-item">
                        <span class="profile-stat-label"><i class="bi bi-gem"></i> Gems</span>
                        <span class="profile-stat-value">@(_gems.HasValue ? _gems.Value.ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("cs-CZ")) : "—")</span>
                    </div>
                    <div class="profile-stat-item">
                        <span class="profile-stat-label"><i class="bi bi-currency-dollar"></i> Money</span>
                        <span class="profile-stat-value">@(_money.HasValue ? _money.Value.ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("cs-CZ")) : "—")</span>
                    </div>
                    <div class="profile-stat-item">
                        <span class="profile-stat-label"><i class="bi bi-receipt"></i> Purchases</span>
                        <span class="profile-stat-value">@(_purchasesCount)</span>
                    </div>
                    <div class="profile-stat-item">
                        <span class="profile-stat-label"><i class="bi bi-clock"></i> Play time</span>
                        <span class="profile-stat-value">@FormatPlayTime(_statistics?.PlayTimeSeconds ?? 0L)</span>
                    </div>
                    <div class="profile-stat-item">
                        <span class="profile-stat-label"><i class="bi bi-emoji-dizzy"></i> Deaths</span>
                        <span class="profile-stat-value">@((_statistics?.Deaths ?? 0).ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("cs-CZ")))</span>
                    </div>
                    <div class="profile-stat-item">
                        <span class="profile-stat-label"><i class="bi bi-crosshair"></i> Player kills</span>
                        <span class="profile-stat-value">@((_statistics?.PlayerKills ?? 0).ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("cs-CZ")))</span>
                    </div>
                    <div class="profile-stat-item">
                        <span class="profile-stat-label"><i class="bi bi-geo-alt"></i> Blocks travelled</span>
                        <span class="profile-stat-value">@((_statistics?.BlocksTravelled ?? 0L).ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("cs-CZ")))</span>
                    </div>
                }
                else
                {
                    @if (_gems.HasValue && _gems.Value != 0)
                    {
                        <div class="profile-stat-item">
                            <span class="profile-stat-label"><i class="bi bi-gem"></i> Gems</span>
                            <span class="profile-stat-value">@(_gems.Value.ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("cs-CZ")))</span>
                        </div>
                    }

                    @if (_money.HasValue && _money.Value != 0)
                    {
                        <div class="profile-stat-item">
                            <span class="profile-stat-label"><i class="bi bi-currency-dollar"></i> Money</span>
                            <span class="profile-stat-value">@(_money.Value.ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("cs-CZ")))</span>
                        </div>
                    }

                    @if (_purchasesCount > 0)
                    {
                        <div class="profile-stat-item">
                            <span class="profile-stat-label"><i class="bi bi-receipt"></i> Purchases</span>
                            <span class="profile-stat-value">@(_purchasesCount)</span>
                        </div>
                    }

                    @if ((_statistics?.PlayTimeSeconds ?? 0L) > 0)
                    {
                        <div class="profile-stat-item">
                            <span class="profile-stat-label"><i class="bi bi-clock"></i> Play time</span>
                            <span class="profile-stat-value">@FormatPlayTime(_statistics?.PlayTimeSeconds ?? 0L)</span>
                        </div>
                    }

                    @if ((_statistics?.Deaths ?? 0) > 0)
                    {
                        <div class="profile-stat-item">
                            <span class="profile-stat-label"><i class="bi bi-emoji-dizzy"></i> Deaths</span>
                            <span class="profile-stat-value">@((_statistics?.Deaths ?? 0).ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("cs-CZ")))</span>
                        </div>
                    }

                    @if ((_statistics?.PlayerKills ?? 0) > 0)
                    {
                        <div class="profile-stat-item">
                            <span class="profile-stat-label"><i class="bi bi-flag"></i> Player kills</span>
                            <span class="profile-stat-value">@((_statistics?.PlayerKills ?? 0).ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("cs-CZ")))</span>
                        </div>
                    }

                    @if ((_statistics?.BlocksTravelled ?? 0L) > 0)
                    {
                        <div class="profile-stat-item">
                            <span class="profile-stat-label"><i class="bi bi-geo-alt"></i> Blocks travelled</span>
                            <span class="profile-stat-value">@((_statistics?.BlocksTravelled ?? 0L).ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("cs-CZ")))</span>
                        </div>
                    }
                }
            </div>
        </div>
        </div>
    </div>

    <h2 class="mt-4">Purchase history</h2>
    @if (_transactions == null || !_transactions.Any())
    {
        <div class="small text-muted">No purchases found.</div>
    }
    else
    {
        @foreach (var tx in _transactions
            .Where(t => !string.IsNullOrWhiteSpace(t.Status)
                && (t.Status.IndexOf("RCON_OK", StringComparison.OrdinalIgnoreCase) >= 0
                    || string.Equals(t.Status, "succeeded", StringComparison.OrdinalIgnoreCase))
                && t.Amount > 0)
            .OrderByDescending(t => t.CreatedAt)
            .Take(100))
        {
            var txItems = ParseItems(tx.ItemsJson);
            <div class="purchase-history-group mt-3">
                <div class="cart-total-profile">
                    <span>@tx.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</span>
                    <span class="text-success">€@tx.Amount.ToString("F2")</span>
                </div>

                @if (txItems.Any())
                {
                    <div class="product-grid">
                        @foreach (var item in txItems)
                        {
                            <div class="product">
                                <div class="card h-100">
                                    @if (!string.IsNullOrEmpty(item.Product?.Image))
                                    {
                                        <img src="@item.Product.Image" class="product-image" alt="@item.Product?.Name">
                                    }
                                    else
                                    {
                                        <div style="height: 120px;">
                                            <i class="bi bi-box-fill text-white" style="font-size: 2rem;"></i>
                                        </div>
                                    }
                                    <div class="">
                                        <h3 class="">@item.Product?.Name</h3>
                                        <small class="text-muted">@item.Product?.Server?.Name</small>
                                        <div class="mt-auto">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <strong class="text-primary">€@((item.Product?.Price ?? 0).ToString("F2"))</strong>
                                                <span class="badge bg-secondary">×@item.Quantity</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    }
}

@code {
    [Parameter] public string? Name { get; set; }

    private bool _loaded = false;
    private bool _loggedIn = false;
    private string? _username;
    private string? _skinUrl;
    private string? _rankName;
    private string? _rankHex;
    private int? _gems = null;
    private int? _money = null;
    private List<TransactionResponse>? _transactions;
    private PlayerStatistics? _statistics;

    private bool _isOnline = false;
    private int _purchasesCount = 0;

    // Track which profile is currently loaded to avoid redundant reloads
    private string? _loadedFor;

    protected override async Task OnParametersSetAsync()
    {
        // Resolve the effective username (URL param takes priority)
        string? effectiveUsername;
        bool requiresLogin;

        if (!string.IsNullOrWhiteSpace(Name))
        {
            effectiveUsername = Name;
            requiresLogin = false;
        }
        else
        {
            var info = await UserService.GetUserInfoAsync();
            if (!info.LoggedIn)
            {
                _loggedIn = false;
                _loaded = true;
                _loadedFor = null;
                return;
            }
            effectiveUsername = info.Username;
            requiresLogin = true;
        }

        // Skip reload if we already have data for this player
        if (_loadedFor == effectiveUsername)
            return;

        _loaded = false;
        _loggedIn = true;
        _username = effectiveUsername;
        _skinUrl = requiresLogin
            ? (await UserService.GetUserInfoAsync()).Skin
            : $"https://minotar.net/helm/{Uri.EscapeDataString(effectiveUsername!)}/100";
        _gems = null;
        _money = null;
        _rankName = null;
        _rankHex = null;
        _transactions = null;

        try
        {
            // Fetch player first (HTTP) then perform DB queries sequentially to avoid concurrent DbContext usage
            var player = await GameServerService.GetPlayerInfoAsync(_username!);
            if (player != null)
            {
                _gems = player.Gems;
                _money = player.Money;
                _rankName = ParseRankName(player.Rank);
                _statistics = player.Statistics;
                if (!string.IsNullOrWhiteSpace(_rankName))
                {
                    var tr = await TeamRankService.GetByNameAsync(_rankName);
                    if (tr != null) _rankHex = tr.HexColor;
                }
            }

            // Transactions and scoreboard access the same DbContext; run them sequentially to avoid EF Core concurrency errors
            var txs = (await TransactionsService.GetByUsernameAsync(_username!))?.ToList() ?? new List<TransactionResponse>();
            _transactions = txs;

            // compute purchases count (successful purchases only)
            _purchasesCount = _transactions?.Count(t =>
                    !string.IsNullOrWhiteSpace(t.Status)
                    && (t.Status.IndexOf("RCON_OK", StringComparison.OrdinalIgnoreCase) >= 0
                        || string.Equals(t.Status, "succeeded", StringComparison.OrdinalIgnoreCase))
                    && t.Amount > 0) ?? 0;

            // Determine online status by querying active players; tolerate failures
            try
            {
                var online = await GameServerService.GetOnlinePlayersAsync();
                _isOnline = online?.Players?.Any(p => string.Equals(p.Name, _username, StringComparison.OrdinalIgnoreCase)) == true;
            }
            catch
            {
                _isOnline = false;
            }

            try
            {
                var board = await ShopScoreboardService.GetScoreboardAsync(ScoreboardPeriod.AllTime, 200);
                var pos = board?.FindIndex(e => string.Equals(e.MinecraftUsername, _username, StringComparison.OrdinalIgnoreCase));
                if (pos.HasValue && pos.Value >= 0)
                {
                    // Could display position if desired
                }
            }
            catch { }

            _loadedFor = effectiveUsername;
        }
        catch
        {
            // best-effort — profile shell still renders with whatever data was set
        }
        finally
        {
            _loaded = true;
            StateHasChanged();
        }
    }

    private static string? ParseRankName(string? rank)
    {
        if (string.IsNullOrWhiteSpace(rank)) return null;
        if (rank.StartsWith("%img_") && rank.EndsWith("%"))
            return rank[5..^1].ToUpperInvariant();
        return rank.ToUpperInvariant();
    }

    private void GoLogin() => NavigationManager.NavigateTo("/login");

    private string FormatPlayTime(long seconds)
    {
        if (seconds <= 0) return "0m";
        var ts = System.TimeSpan.FromSeconds(seconds);
        var days = ts.Days;
        var hours = ts.Hours;
        var minutes = ts.Minutes;
        var parts = new System.Collections.Generic.List<string>();
        if (days > 0) parts.Add($"{days}d");
        if (hours > 0) parts.Add($"{hours}h");
        if (minutes > 0) parts.Add($"{minutes}m");
        if (parts.Count == 0) parts.Add("0m");
        return string.Join(" ", parts);
    }

    private List<ProductQuantityDto> ParseItems(string? itemsJson)
    {
        if (string.IsNullOrWhiteSpace(itemsJson)) return new();
        try
        {
            var opts = new System.Text.Json.JsonSerializerOptions(System.Text.Json.JsonSerializerDefaults.Web) { PropertyNameCaseInsensitive = true };
            return System.Text.Json.JsonSerializer.Deserialize<List<ProductQuantityDto>>(itemsJson, opts) ?? new();
        }
        catch
        {
            return new();
        }
    }
}
