@page "/gems"
@using SentrySMP.Shared.DTOs
@using SentrySMP.Shared.Interfaces
@inject ISentryApi Api
@inject ILogger<Gems> Logger
@inject SentrySMP.App.Components.State.CartState CartState
@inject SentrySMP.App.Components.State.CartSidebarState SidebarState
@inject IJSRuntime JS
@inject IPurchaseTrackingService PurchaseTrackingService
@inject SentrySMP.App.Authentication.UserService UserService
@rendermode InteractiveServer
@implements IDisposable
<PageTitle>Gems - SentrySMP</PageTitle>
<!--
Server filter dropdown
            @if (gems?.Any() == true)
            {
                <div class="mb-3 d-flex align-items-center gap-2">
                    <label for="serverFilter" class="form-label mb-0">Filter by server:</label>
                    <select id="serverFilter" class="form-select w-auto" @onchange="OnServerFilterChanged">
                        <option value="">All servers</option>
                        @foreach (var server in servers)
                        {
                            <option value="@server.Id" selected="@(server.Id == selectedServerId)">@server.Name</option>
                        }
                    </select>
                </div>
            }
-->
            @if (loading)
            {
                <div class="d-flex justify-content-center">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            }
            else if (errorMessage != null)
            {
                <div class="alert alert-danger" role="alert">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    @errorMessage
                </div>
            }
            else if (filteredGems?.Any() == true)
            {
                <div class="product-grid">
                    @foreach (var gem in filteredGems)
                    {
                        <div class="product">
                            <div class="card h-100">
                                @if (!string.IsNullOrEmpty(gem.Image))
                                {
                                    <img src="@gem.Image" class="product-image" @onclick="() => ShowGemDetails(gem)" alt="@gem.Name">
                                }
                                else
                                {
                                    <div class="" style="height: 200px;">
                                        <i class="bi bi-box-fill text-white" style="font-size: 3rem;"></i>
                                    </div>
                                }
                                <div class="">
                                    <h3 class="">@gem.Name</h3>
                                    <small class="text-muted">@gem.Server?.Name</small>
                                    <div class="mt-auto">
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <div class="price-container">
                                                @if (gem.Sale > 0)
                                                {
                                                    <p class="original-price" title="Original price">
                                                        €@gem.Price.ToString("F2")
                                                    </p>
                                                    <p class="discounted-price" title="Sale price">
                                                        €@(CalculateSalePrice(gem.Price, gem.Sale).ToString("F2"))
                                                    </p>
                                                    <span class="discount-badge">@gem.Sale% OFF</span>
                                                }
                                                else
                                                {
                                                    <strong class="text-primary fs-5">€@gem.Price.ToString("F2")</strong>
                                                }
                                            </div>
                                        </div>
                                        @if (gem.GlobalMaxOrder.HasValue)
                                        {
                                            <div class="mb-2">
                                                <small class="text-info">
                                                    <i class="bi bi-info-circle"></i> Limited availability
                                                    @if (_purchasedCounts.TryGetValue($"Gem_{gem.Id}", out var purchased))
                                                    {
                                                        <br /><span class="text-warning">Sold: @purchased/@gem.GlobalMaxOrder</span>
                                                    }
                                                </small>
                                            </div>
                                        }
                                        @{
                                            var remainingQty = GetRemainingQuantity("Gem", gem.Id, gem.GlobalMaxOrder);
                                            var isSoldOut = remainingQty == 0;
                                            var cartItem = CartState.CartItems.FirstOrDefault(i => i.Key.Id == gem.Id && i.Key.Type == "Gem");
                                            var selectedQty = GetSelectedQty(gem.Id);
                                        }
                                        <div class="qty-presets">
                                            @foreach (var qty in QtyPresets)
                                            {
                                                <button class="qty-preset-btn @(selectedQty == qty ? "selected" : "")"
                                                        @onclick="() => SelectQty(gem.Id, qty)"
                                                        disabled="@(qty > remainingQty || isSoldOut)"
                                                        title="@qty×">@qty×</button>
                                            }
                                        </div>
                                        <button class="great-button" @onclick="async () => await AddToCartPreset(gem)" disabled="@isSoldOut">
                                            <i class="bi bi-@(isSoldOut ? "x-circle" : "cart-plus")"></i>
                                            @(isSoldOut ? "Sold Out" : cartItem != null ? "Update Cart" : "Add to Cart")
                                        </button>
                                        @if (cartItem != null)
                                        {
                                            <div class="product-cart-remove">
                                                <button @onclick="async () => await RemoveFromCart(gem)" title="Remove from cart">
                                                    <i class="bi bi-trash"></i> Remove
                                                </button>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info" role="alert">
                    <i class="bi bi-info-circle-fill"></i>
                    No gems available at the moment.
                </div>
            }

<!-- Gem Details Modal (mirrors Keys modal layout) -->
@if (selectedGem != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title">
                        <i class="bi bi-box-fill"></i>
                        @selectedGem.Name
                    </h2>
                    <button type="button" class="btn-close" @onclick="CloseGemDetails"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        @if (!string.IsNullOrEmpty(selectedGem.Image))
                        {
                            <div class="col-md-6">
                                <img src="@selectedGem.Image" class="img-fluid rounded" alt="@selectedGem.Name">
                            </div>
                        }
                        <div class="col-md-@(string.IsNullOrEmpty(selectedGem.Image) ? "12" : "6")">
                            <div class="row" style="padding: 20px">
                                <h2 class="col-sm-8">@selectedGem.Name</h2>
                                @if (!string.IsNullOrEmpty(selectedGem.Description))
                                {
                                    <p class="col-sm-8">@selectedGem.Description</p>
                                }
                                <small class="text-muted">Server: @selectedGem.Server?.Name</small>
                                    <div class="price-container">
                                        @if (selectedGem.Sale > 0)
                                        {
                                            <p class="original-price" title="Original price">
                                                €@selectedGem.Price.ToString("F2")
                                            </p>
                                            <p class="discounted-price" title="Sale price">
                                                €@(CalculateSalePrice(selectedGem.Price, selectedGem.Sale).ToString("F2"))
                                            </p>
                                            <span class="discount-badge">@selectedGem.Sale% OFF</span>
                                        }
                                        else
                                        {
                                            <strong class="text-primary fs-5">€@selectedGem.Price.ToString("F2")</strong>
                                        }
                                    </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    @{
                        var cartItemModal = CartState.CartItems.FirstOrDefault(i => i.Key.Id == selectedGem!.Id && i.Key.Type == "Gem");
                        var remainingQtyModal = GetRemainingQuantity("Gem", selectedGem!.Id, selectedGem.GlobalMaxOrder);
                        var isSoldOutModal = remainingQtyModal == 0;
                    }
                    @if (cartItemModal == null)
                    {
                        <button type="button" class="btn btn-outline-success" @onclick="async () => await AddToCart(selectedGem!)" disabled="@isSoldOutModal">
                            <i class="bi bi-cart-plus"></i> @(isSoldOutModal ? "Sold Out" : "Add to Cart")
                        </button>
                    }
                    else
                    {
                        <div style="display: block ruby;">
                            <div class="quantity-controls">
                                <button class="quantity-btn" @onclick="() => ChangeQuantity(selectedGem!, -1)" disabled="@(cartItemModal.Quantity <= 1)">-</button>
                                <span>@cartItemModal.Quantity</span>
                                <button class="quantity-btn" @onclick="() => ChangeQuantity(selectedGem!, 1)" disabled="@(cartItemModal.Quantity >= Math.Min(10, remainingQtyModal))">+</button>
                            </div>
                            <button class="danger" @onclick="async () => await RemoveFromCart(selectedGem!)" title="Remove from cart">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<GemResponse>? gems;
    private List<GemResponse>? filteredGems;
    private List<ServerResponse> servers = new();
    private int? selectedServerId;
    private bool loading = true;
    private string? errorMessage;
    private GemResponse? selectedGem;

    private bool _cartLoaded = false;
    private int? addedGemId;

    private static readonly int[] QtyPresets = [1, 5, 10, 20];
    private Dictionary<int, int> _selectedQtyMap = new();

    private int GetSelectedQty(int gemId)
    {
        var cartItem = CartState.CartItems.FirstOrDefault(i => i.Key.Id == gemId && i.Key.Type == "Gem");
        if (cartItem != null) return cartItem.Quantity;
        return _selectedQtyMap.GetValueOrDefault(gemId, 1);
    }

    private void SelectQty(int gemId, int qty)
    {
        _selectedQtyMap[gemId] = qty;
    }

    private Dictionary<string, int> _purchasedCounts = new();
    private string? _username;

    protected override async Task OnInitializedAsync()
    {
        CartState.OnChange += OnCartChanged;
        await LoadGems();
        await LoadPurchasedCounts();
    }

    public void Dispose()
    {
        CartState.OnChange -= OnCartChanged;
    }

    private void OnCartChanged() => InvokeAsync(StateHasChanged);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_cartLoaded)
        {
            await CartState.LoadFromStorageAsync(JS);
            _cartLoaded = true;
            StateHasChanged();
        }
    }

    private async Task LoadGems()
    {
        try
        {
            loading = true;
            errorMessage = null;
            gems = (await Api.GetGemsAsync()).ToList();
            // build server list from gems and apply filter
            servers = gems
                .Where(s => s.Server != null)
                .Select(s => s.Server!)
                .GroupBy(s => s.Id)
                .Select(g => g.First())
                .OrderBy(s => s.Name)
                .ToList();
            ApplyServerFilter();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading gems: {ex.Message}";
            Logger.LogError(ex, "Error loading gems");
        }
        finally
        {
            loading = false;
        }
    }

    private void ApplyServerFilter()
    {
        if (selectedServerId.HasValue)
        {
            filteredGems = gems?.Where(s => s.Server?.Id == selectedServerId.Value).ToList();
        }
        else
        {
            filteredGems = gems;
        }
    }

    private void OnServerFilterChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        if (int.TryParse(value, out var id))
        {
            selectedServerId = id;
        }
        else
        {
            selectedServerId = null;
        }
        ApplyServerFilter();
        StateHasChanged();
    }

    private void ShowGemDetails(GemResponse gem)
    {
        selectedGem = gem;
    }

    private void CloseGemDetails()
    {
        selectedGem = null;
    }

    private double CalculateSalePrice(double originalPrice, int salePercentage)
    {
        return originalPrice * (1 - salePercentage / 100.0);
    }

    private async Task AddToCart(GemResponse gem)
    {
        await JS.InvokeVoidAsync("console.log", $"AddToCart: {gem.Name} (ID: {gem.Id})");
        await CartState.AddToCartAsync(gem);
        addedGemId = gem.Id;
        StateHasChanged();
        await Task.Delay(1200);
        if (addedGemId == gem.Id) { addedGemId = null; StateHasChanged(); }
    }

    private async Task AddToCartPreset(GemResponse gem)
    {
        var qty = GetSelectedQty(gem.Id);
        await CartState.SetQuantityAsync(gem, qty);
        SidebarState.Open();
        StateHasChanged();
    }

    private async Task ChangeQuantity(GemResponse gem, int delta)
    {
        await CartState.ChangeQuantityAsync(gem, delta);
    }

    private async Task RemoveFromCart(GemResponse gem)
    {
        await CartState.RemoveFromCartAsync(gem);
        StateHasChanged();
    }

    private async Task AddSelectedToCart()
    {
        if (selectedGem != null)
        {
            await AddToCart(selectedGem);
        }
    }

    private async Task LoadPurchasedCounts()
    {
        if (gems == null) return;
        
        foreach (var gem in gems.Where(c => c.GlobalMaxOrder.HasValue))
        {
            var count = await PurchaseTrackingService.GetGlobalPurchasedAsync("Gem", gem.Id);
            _purchasedCounts[$"Gem_{gem.Id}"] = count;
        }
    }

    private int GetRemainingQuantity(string type, int id, int? globalMaxOrder)
    {
        if (!globalMaxOrder.HasValue) return int.MaxValue;
        
        if (_purchasedCounts.TryGetValue($"{type}_{id}", out var purchased))
        {
            return Math.Max(0, globalMaxOrder.Value - purchased);
        }
        
        return globalMaxOrder.Value;
    }
}
