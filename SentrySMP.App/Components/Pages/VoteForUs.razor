@page "/vote-for-us"

<PageTitle>Vote For Us - SentrySMP</PageTitle>

<div class="vote-container">

    <div class="vote-notice">
        <p>By voting, you <b>help our community grow and thrive</b>. Your support means the world to us and makes this server <b>a better place for everyone</b>. Together we can build something amazing!</p>
    </div>

    <div class="vote-grid">
        <a href="https://minecraftservers.org/vote/670535" target="_blank" class="vote-link">
            <div class="vote-card">
                <div class="vote-card-icon"><i class="bi bi-trophy-fill"></i></div>
                <div class="vote-card-body">
                    <div class="vote-card-name">MinecraftServers.org</div>
                    <div class="vote-card-action">Vote Now <i class="bi bi-arrow-right"></i></div>
                </div>
            </div>
        </a>
        <a href="https://craftlist.org/sentrysmp-fqjod" target="_blank" class="vote-link">
            <div class="vote-card">
                <div class="vote-card-icon"><i class="bi bi-list-stars"></i></div>
                <div class="vote-card-body">
                    <div class="vote-card-name">CraftList.org</div>
                    <div class="vote-card-action">Vote Now <i class="bi bi-arrow-right"></i></div>
                </div>
            </div>
        </a>
    </div>

</div>