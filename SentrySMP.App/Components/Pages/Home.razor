		max-width: 1200px;
		padding: 0;
	}

	.latest-announcements {
		max-width: 1200px;
		margin: 40px auto;
		padding: 0 20px;
	}

	.announcements-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
		gap: 20px;
	}

	.latest-announcements h2 {
		text-align: center;
		margin-bottom: 30px;
		color: white;
	}
</style>
