@implements IDisposable

@code {
    [Microsoft.AspNetCore.Components.Inject]
    public SentrySMP.App.Services.ThemeService ThemeService { get; set; } = default!;

    [Microsoft.AspNetCore.Components.Inject]
    public Microsoft.JSInterop.IJSRuntime JSRuntime { get; set; } = default!;

    [Microsoft.AspNetCore.Components.Inject]
    public SentrySMP.App.Services.MenuToggleService MenuToggleService { get; set; } = default!;

    private bool isLight;
    private bool initialized = false;
    private List<ShopScoreboardEntryDto>? TopPlayers;

    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _ = MenuToggleService.CloseAsync();
        _ = JSRuntime.InvokeVoidAsync("eval", "window.scrollTo({top:0,behavior:'smooth'})");
        InvokeAsync(StateHasChanged);
    }

    private string NavItemClass(string href)
    {
        var current = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).TrimEnd('/');
        var target = href.TrimEnd('/');
        bool isActive = target == ""
            ? current == ""
            : string.Equals(current, target, StringComparison.OrdinalIgnoreCase)
              || current.StartsWith(target + "/", StringComparison.OrdinalIgnoreCase);
        return isActive ? "nav-item nav-item--active" : "nav-item";
    }

    protected override async System.Threading.Tasks.Task OnInitializedAsync()
    {
        try
        {
            var excludedNames = new[] { "Taneq", "webdev" };
            var all = await ScoreboardService.GetScoreboardAsync(ScoreboardPeriod.AllTime, 50);
            TopPlayers = all?
                .Where(e => !string.IsNullOrWhiteSpace(e.MinecraftUsername))
                .Where(e => e.TotalPaid > 0)
                .Where(e => !excludedNames.Contains(e.MinecraftUsername, StringComparer.OrdinalIgnoreCase))
                .Where(e => !string.Equals(e.MinecraftUsername?.Trim(), "<unknown>", StringComparison.OrdinalIgnoreCase))
                .Where(e => !e.MinecraftUsername.StartsWith('.'))
                .OrderByDescending(e => e.TotalPaid)
                .Take(5)
                .ToList();
        }
        catch
        {
            TopPlayers = new List<ShopScoreboardEntryDto>();
        }
    }

    protected override async System.Threading.Tasks.Task OnAfterRenderAsync(bool firstRender)
    {
        if (!initialized && firstRender)
        {
            initialized = true;
            // Initialize theme from saved preference (do JS interop after first render)
            await ThemeService.InitializeAsync(JSRuntime);
            // initialize menu toggle service so it can call JS
            try { await MenuToggleService.InitializeAsync(JSRuntime); } catch { }
            // Represent switch as 'light enabled' (checked = light). Default empty preference will show light on.
            isLight = !ThemeService.IsDark;
            ThemeService.OnThemeChanged += ThemeChanged;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async System.Threading.Tasks.Task ToggleNav()
    {
        try
        {
            await MenuToggleService.ToggleAsync();
        }
        catch { }
    }

    private void ThemeChanged(bool dark)
    {
        // Update local light-state when theme changes
        isLight = !dark;
        InvokeAsync(StateHasChanged);
    }

    // Two-way bind target that forwards changes to ThemeService
    public bool IsLightBindable
    {
        get => isLight;
        set
        {
            if (isLight == value) return;
            isLight = value;
            // Checkbox represents light enabled; pass inverse (dark) to ThemeService
            _ = ThemeService.SetThemeAsync(!value);
            InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
        try
        {
            ThemeService.OnThemeChanged -= ThemeChanged;
        }
        catch { }
    }
}